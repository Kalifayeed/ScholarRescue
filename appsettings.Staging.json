{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ScholarRescue_Staging;Username=postgres;Password=${STAGING_DB_PASSWORD}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Stripe": {
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}"
  },
  "Email": {
    "SmtpHost": "smtp.sendgrid.net",
    "SmtpPort": 587,
    "SmtpUsername": "apikey",
    "SmtpPassword": "${SMTP_PASSWORD}",
    "FromAddress": "noreply@scholarrescue.com",
    "FromName": "ScholarRescue"
  },
  "Security": {
    "RequireHttps": true,
    "HstsMaxAgeDays": 30,
    "EnableCsrf": true
  },
  "Platform": {
    "Name": "ScholarRescue (Staging)",
    "BaseUrl": "https://staging.scholarrescue.com",
    "SupportEmail": "support@scholarrescue.com",
    "MaxUploadSizeMb": 25
  }
}