{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=scholarrescue;Username=scholarrescue_user;Password=${PROD_DB_PASSWORD}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Stripe": {
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}"
  },
  "Email": {
    "SmtpHost": "smtp.sendgrid.net",
    "SmtpPort": 587,
    "SmtpUsername": "apikey",
    "SmtpPassword": "${SMTP_PASSWORD}",
    "FromAddress": "noreply@scholarrescue.com",
    "FromName": "ScholarRescue"
  },
  "Security": {
    "RequireHttps": true,
    "HstsMaxAgeDays": 365,
    "EnableCsrf": true,
    "RateLimitPerMinute": 60,
    "MaxLoginAttempts": 5,
    "AccountLockoutMinutes": 15
  },
  "Platform": {
    "Name": "ScholarRescue",
    "BaseUrl": "https://www.scholarrescue.com",
    "SupportEmail": "support@scholarrescue.com",
    "MaxUploadSizeMb": 25,
    "Version": "1.0.0"
  }
}