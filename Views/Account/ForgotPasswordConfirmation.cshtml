@{
    ViewData["Title"] = "Password Reset Link Sent";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 text-center">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-5">
                        <i class="bi bi-envelope-check text-primary" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold mt-3">Check Your Email</h3>
                        <p class="text-muted">
                            If an account exists for that email, a password reset link has been sent.
                            Please check your inbox and follow the instructions.
                        </p>
                        <hr />
                        <p class="small text-muted">
                            Didn't receive the email? Check your spam folder or
                            <a asp-action="ForgotPassword" class="text-primary">try again</a>.
                        </p>
                        <a asp-action="Login" class="btn btn-primary mt-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Back to Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>