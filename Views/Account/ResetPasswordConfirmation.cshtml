@{
    ViewData["Title"] = "Password Reset Success";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7 text-center">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-5">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold mt-3">Password Reset Successful</h3>
                        <p class="text-muted">
                            Your password has been reset. Please log in with your new password.
                        </p>
                        <hr />
                        <a asp-action="Login" class="btn btn-primary mt-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Log In
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>