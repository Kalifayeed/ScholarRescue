@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow border-danger">
                <div class="card-body py-5">
                    <div class="display-1 text-danger mb-4">
                        <i class="bi bi-shield-exclamation"></i>
                    </div>
                    <h1 class="text-danger fw-bold mb-3">403 - Access Denied</h1>
                    <p class="lead text-muted mb-4">
                        You do not have permission to access this resource.
                        Please contact your administrator if you believe this is an error.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="Login" asp-controller="Account" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right"></i> Log In
                        </a>
                        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">
                            <i class="bi bi-house"></i> Go Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}