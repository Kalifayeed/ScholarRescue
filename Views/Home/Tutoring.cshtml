@{
    ViewData["Title"] = "Tutoring Services";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Hero Section -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-white mb-3">Tutoring Services</h1>
                <p class="text-white-50 lead mb-0">
                    Personalized one-on-one tutoring from qualified academic specialists across all subjects and academic levels.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4 me-2">
                    <i class="bi bi-rocket-takeoff me-2"></i>Get Started
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="fw-bold mb-4">Expert Academic Tutoring Tailored to Your Needs</h2>
                <p class="text-muted lead mb-4">
                    Scholarly success often requires more than classroom instruction. Our tutoring service connects students with qualified academic specialists who provide personalized guidance across a wide range of subjects and disciplines.
                </p>
                <p class="text-muted">
                    Whether you are struggling with difficult concepts, preparing for examinations, improving academic writing skills, or seeking assistance with research methods, our tutors are available to help you achieve your goals.
                </p>
                <p class="text-muted">
                    Each session is tailored to your specific learning needs and academic level, ensuring focused support that strengthens understanding rather than simply providing answers. We emphasize critical thinking, problem-solving, and long-term academic development so that students gain confidence and independence in their studies.
                </p>
                <p class="text-muted">
                    From high school coursework to advanced postgraduate subjects, our tutors work closely with students to identify challenges, develop effective study strategies, and improve academic performance. Flexible scheduling, one-on-one interaction, and ongoing support make our tutoring service an ideal solution for students seeking reliable academic guidance throughout their educational journey.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">Why Choose Our Tutoring Service</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-person-check fs-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">Qualified Specialists</h6>
                        <p class="text-muted small mb-0">All tutors are verified professionals with expertise in their respective fields.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-graph-up-arrow fs-4 text-success"></i>
                        </div>
                        <h6 class="fw-bold">Personalized Approach</h6>
                        <p class="text-muted small mb-0">Every session is customized to address your specific academic challenges and goals.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-info bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-calendar-check fs-4 text-info"></i>
                        </div>
                        <h6 class="fw-bold">Flexible Scheduling</h6>
                        <p class="text-muted small mb-0">Schedule sessions at times that work best for you, with ongoing support as needed.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 cta-section">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Improve Your Academic Performance?</h2>
        <p class="text-white-50 mb-4">Connect with a qualified tutor today and take the next step toward academic success.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started
            </a>
            <a asp-controller="Home" asp-action="OrderNow" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-cart me-2"></i>Order Now
            </a>
            <a asp-controller="Account" asp-action="Register" asp-route-userType="Writer" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-person-plus me-2"></i>Register as Tutor
            </a>
        </div>
    </div>
</section>

<style>
    .cta-section { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
</style>