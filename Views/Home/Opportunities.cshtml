@{
    ViewData["Title"] = "Opportunities";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Page Header -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <h1 class="display-5 fw-bold text-white">Opportunities</h1>
        <p class="text-white-50 lead mb-0">Discover what ScholarRescue has to offer</p>
    </div>
</section>

<!-- Opportunities Overview -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Why Join ScholarRescue?</h2>
            <p class="text-muted">We provide a comprehensive platform for academic support professionals and students alike</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 p-4">
                    <div class="text-center mb-3">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width:64px;height:64px;">
                            <i class="bi bi-book fs-3 text-primary"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold text-center">Available Subjects</h5>
                    <p class="text-muted text-center">We cover a wide range of academic disciplines including:</p>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Sciences & Mathematics</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Business & Management</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Engineering & Technology</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Nursing & Health Sciences</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Social Sciences</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Humanities & Arts</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Law & Legal Studies</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Education & Pedagogy</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 p-4">
                    <div class="text-center mb-3">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width:64px;height:64px;">
                            <i class="bi bi-layers fs-3 text-success"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold text-center">Academic Levels</h5>
                    <p class="text-muted text-center">Support students at every level of their academic journey:</p>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Undergraduate / Bachelor's</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Master's / MBA</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Doctoral / PhD</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Post-Doctoral Research</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Professional Certifications</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>High School Advanced</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="card border-0 shadow-sm h-100 p-4">
                    <div class="text-center mb-3">
                        <div class="rounded-circle bg-info bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width:64px;height:64px;">
                            <i class="bi bi-clock-history fs-3 text-info"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold text-center">Flexible Work Schedule</h5>
                    <p class="text-muted text-center">Enjoy complete flexibility with your work arrangements:</p>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Work from anywhere in the world</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Set your own hours</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Choose your requests</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>No minimum hours required</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Part-time or full-time</li>
                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Balance with other commitments</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Expected Earnings -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Expected Earnings</h2>
            <p class="text-muted">Competitive rates that reward expertise and dedication</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100 p-4">
                    <div class="card-body">
                        <i class="bi bi-cash-stack fs-1 text-success mb-3"></i>
                        <h5 class="fw-bold">Entry Level</h5>
                        <p class="text-muted small">New tutors starting on the platform with verified qualifications.</p>
                        <span class="badge bg-success">Competitive Base Rate</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100 p-4">
                    <div class="card-body">
                        <i class="bi bi-graph-up-arrow fs-1 text-primary mb-3"></i>
                        <h5 class="fw-bold">Experienced</h5>
                        <p class="text-muted small">Tutors with proven track record and positive reviews.</p>
                        <span class="badge bg-primary">Enhanced Rate</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm text-center h-100 p-4">
                    <div class="card-body">
                        <i class="bi bi-star fs-1 text-warning mb-3"></i>
                        <h5 class="fw-bold">Expert</h5>
                        <p class="text-muted small">Top-rated tutors with extensive experience and advanced degrees.</p>
                        <span class="badge bg-warning text-dark">Premium Rate</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-4">
            <p class="text-muted small">Earnings vary based on subject, complexity, and academic level. Payouts are processed through our secure wallet system.</p>
        </div>
    </div>
</section>

<!-- Services Available -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Services You Can Provide</h2>
            <p class="text-muted">Multiple ways to share your academic expertise</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-person-workspace text-primary fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Tutoring</h6>
                        <p class="text-muted small mb-0">One-on-one academic tutoring sessions across various subjects.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-search text-success fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Research Guidance</h6>
                        <p class="text-muted small mb-0">Guide students through research methodology and analysis.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-pencil text-info fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Editing & Proofreading</h6>
                        <p class="text-muted small mb-0">Refine academic papers for clarity, grammar, and style.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-lightbulb text-warning fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Academic Coaching</h6>
                        <p class="text-muted small mb-0">Help students develop study skills and academic strategies.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-book text-danger fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Citation Assistance</h6>
                        <p class="text-muted small mb-0">Help with referencing in APA, MLA, Chicago, Harvard formats.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-start gap-3">
                    <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-layout-text-window text-secondary fs-5"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Formatting</h6>
                        <p class="text-muted small mb-0">Ensure papers meet institutional formatting requirements.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Explore Opportunities?</h2>
        <p class="text-white-50 mb-4">Create your account and start your academic support journey today.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg">Get Started</a>
            <a asp-controller="Home" asp-action="BecomeATutor" class="btn btn-outline-light btn-lg">Become a Tutor</a>
        </div>
    </div>
</section>