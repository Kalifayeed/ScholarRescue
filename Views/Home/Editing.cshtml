@{
    ViewData["Title"] = "Editing Services";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Hero Section -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-white mb-3">Editing Services</h1>
                <p class="text-white-50 lead mb-0">
                    Professional academic editing to improve clarity, coherence, structure, and presentation while preserving your original voice.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4 me-2">
                    <i class="bi bi-rocket-takeoff me-2"></i>Get Started
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="fw-bold mb-4">Professional Editing for Academic Excellence</h2>
                <p class="text-muted lead mb-4">
                    Even well-written academic papers can benefit from professional editing. Our editing service focuses on improving clarity, coherence, structure, and academic presentation while preserving the original meaning and voice of your work.
                </p>
                <p class="text-muted">
                    We carefully review documents to identify grammatical errors, awkward phrasing, inconsistencies, and organizational weaknesses that may affect readability and academic quality. Our editors evaluate sentence construction, paragraph flow, argument development, academic tone, and overall document structure.
                </p>
                <p class="text-muted">
                    We also ensure consistency in terminology, formatting, and citation presentation where applicable. Whether you are preparing a research paper, dissertation chapter, journal manuscript, coursework assignment, or personal statement, our editing specialists help transform rough drafts into polished academic documents.
                </p>
                <p class="text-muted">
                    The editing process is designed to enhance communication and strengthen the impact of your ideas while maintaining academic integrity. By improving readability and professionalism, we help students and researchers present their work with greater confidence and meet the expectations of instructors, supervisors, reviewers, and academic institutions.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">Why Choose Our Editing Service</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-info bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-pencil fs-4 text-info"></i>
                        </div>
                        <h6 class="fw-bold">Clarity & Coherence</h6>
                        <p class="text-muted small mb-0">We improve sentence construction, paragraph flow, and argument development.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-file-check fs-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">Academic Tone</h6>
                        <p class="text-muted small mb-0">We refine your academic voice while preserving your original meaning.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-journal-text fs-4 text-success"></i>
                        </div>
                        <h6 class="fw-bold">Comprehensive Review</h6>
                        <p class="text-muted small mb-0">Evaluation of grammar, structure, consistency, and citation presentation.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 cta-section">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Polish Your Academic Work?</h2>
        <p class="text-white-50 mb-4">Transform your rough draft into a polished, professional academic document.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started
            </a>
            <a asp-controller="Home" asp-action="OrderNow" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-cart me-2"></i>Order Now
            </a>
            <a asp-controller="Account" asp-action="Register" asp-route-userType="Writer" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-person-plus me-2"></i>Register as Tutor
            </a>
        </div>
    </div>
</section>

<style>
    .cta-section { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
</style>