@{
    ViewData["Title"] = "Citation Assistance";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Hero Section -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-white mb-3">Citation Assistance</h1>
                <p class="text-white-50 lead mb-0">
                    Expert help with citations and references in APA, MLA, Chicago, Harvard, IEEE, OSCOLA, and more.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4 me-2">
                    <i class="bi bi-rocket-takeoff me-2"></i>Get Started
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="fw-bold mb-4">Accurate Citations for Academic Integrity</h2>
                <p class="text-muted lead mb-4">
                    Proper citation is essential for maintaining academic integrity and avoiding plagiarism. Our citation assistance service helps students correctly cite and reference sources using widely accepted academic styles.
                </p>
                <p class="text-muted">
                    Whether you are struggling with in-text citations, reference lists, bibliographies, footnotes, or source formatting, our specialists are available to guide you through the process. We help students understand citation requirements, organize sources effectively, and apply style guidelines consistently throughout their documents.
                </p>
                <p class="text-muted">
                    Our team can review existing references, identify citation errors, and ensure compliance with institutional and disciplinary standards. We work with APA, MLA, Chicago, Harvard, IEEE, OSCOLA, and many other citation formats.
                </p>
                <p class="text-muted">
                    Citation requirements often vary between universities, departments, and publication formats. As a result, many students lose marks due to formatting mistakes despite producing strong academic content. Our citation assistance service helps eliminate these issues by providing accurate guidance and detailed review. This ensures that your work demonstrates academic honesty, properly credits original authors, and meets the citation expectations of your institution.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">Why Choose Our Citation Assistance Service</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-book fs-4 text-danger"></i>
                        </div>
                        <h6 class="fw-bold">Multiple Formats</h6>
                        <p class="text-muted small mb-0">Support for APA, MLA, Chicago, Harvard, IEEE, OSCOLA, and many more.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-check-circle fs-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">Error Detection</h6>
                        <p class="text-muted small mb-0">Identification and correction of citation errors and formatting inconsistencies.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-shield-check fs-4 text-success"></i>
                        </div>
                        <h6 class="fw-bold">Academic Integrity</h6>
                        <p class="text-muted small mb-0">Ensure proper source attribution and compliance with institutional standards.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 cta-section">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Get Your Citations Right?</h2>
        <p class="text-white-50 mb-4">Ensure your references are accurate, complete, and properly formatted.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started
            </a>
            <a asp-controller="Home" asp-action="OrderNow" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Request Support
            </a>
            <a asp-controller="Account" asp-action="Register" asp-route-userType="Writer" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-person-plus me-2"></i>Register as Tutor
            </a>
        </div>
    </div>
</section>

<style>
    .cta-section { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
</style>