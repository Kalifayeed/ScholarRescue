@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Page Header -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <h1 class="display-5 fw-bold text-white">About ScholarRescue</h1>
        <p class="text-white-50 lead mb-0">Connecting students with academic excellence</p>
    </div>
</section>

<!-- Company Overview -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h2 class="fw-bold mb-3">Our Story</h2>
                <p class="text-muted">
                    ScholarRescue was founded with a singular mission: to create a trusted platform where students can access high-quality academic support from verified professionals. We understand the challenges students face in their academic journey, and we believe that everyone deserves access to expert guidance.
                </p>
                <p class="text-muted">
                    Our platform connects students with qualified tutors, research mentors, editors, proofreaders, and academic support professionals who are passionate about helping students succeed. Every professional on our platform undergoes a rigorous verification process to ensure the highest standards of quality.
                </p>
            </div>
            <div class="col-lg-6 text-center">
                <div class="rounded-4 p-5" style="background:var(--bg-main);">
                    <i class="bi bi-mortarboard" style="font-size:6rem;color:var(--primary);opacity:0.3;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-bullseye fs-4 text-primary"></i>
                        </div>
                        <h4 class="fw-bold">Our Mission</h4>
                        <p class="text-muted">
                            To provide a reliable, transparent, and accessible platform that connects students with qualified academic professionals, empowering them to achieve their educational goals through expert guidance and support.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="rounded-circle bg-accent bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;background:rgba(245,166,35,0.15);">
                            <i class="bi bi-eye fs-4" style="color:var(--accent);"></i>
                        </div>
                        <h4 class="fw-bold">Our Vision</h4>
                        <p class="text-muted">
                            To become the world's most trusted academic support platform, fostering a global community of learners and educators dedicated to academic excellence and intellectual growth.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How ScholarRescue Works -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How ScholarRescue Works</h2>
            <p class="text-muted">A simple, transparent process from start to finish</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="text-center">
                    <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center fw-bold fs-4 mb-3" style="width:56px;height:56px;">1</div>
                    <h6 class="fw-bold">Create Account</h6>
                    <p class="text-muted small">Sign up for free as a student or tutor.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center">
                    <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center fw-bold fs-4 mb-3" style="width:56px;height:56px;">2</div>
                    <h6 class="fw-bold">Submit Request</h6>
                    <p class="text-muted small">Describe your academic support needs.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center">
                    <div class="rounded-circle text-white d-inline-flex align-items-center justify-content-center fw-bold fs-4 mb-3" style="width:56px;height:56px;background:var(--accent);">3</div>
                    <h6 class="fw-bold">Get Matched</h6>
                    <p class="text-muted small">We match you with the right expert.</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="text-center">
                    <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center fw-bold fs-4 mb-3" style="width:56px;height:56px;">4</div>
                    <h6 class="fw-bold">Succeed</h6>
                    <p class="text-muted small">Receive quality support and achieve your goals.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Benefits -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <h3 class="fw-bold mb-4">Benefits for Students</h3>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                    <div>
                        <strong>Access to Verified Experts</strong>
                        <p class="text-muted small mb-0">Connect with qualified professionals who have been thoroughly vetted.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                    <div>
                        <strong>Transparent Pricing</strong>
                        <p class="text-muted small mb-0">Know exactly what you'll pay with no hidden fees.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                    <div>
                        <strong>Secure Payments</strong>
                        <p class="text-muted small mb-0">Your money is held in escrow until you approve the work.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                    <div>
                        <strong>Real-Time Tracking</strong>
                        <p class="text-muted small mb-0">Monitor the progress of your request at every step.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-success fs-5 mt-1"></i>
                    <div>
                        <strong>Direct Communication</strong>
                        <p class="text-muted small mb-0">Message your tutor directly through our secure platform.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h3 class="fw-bold mb-4">Benefits for Tutors</h3>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-primary fs-5 mt-1"></i>
                    <div>
                        <strong>Flexible Schedule</strong>
                        <p class="text-muted small mb-0">Work when you want, from wherever you are.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-primary fs-5 mt-1"></i>
                    <div>
                        <strong>Competitive Earnings</strong>
                        <p class="text-muted small mb-0">Earn competitive rates for your academic expertise.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-primary fs-5 mt-1"></i>
                    <div>
                        <strong>Secure Payments</strong>
                        <p class="text-muted small mb-0">Get paid reliably through our secure payout system.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-primary fs-5 mt-1"></i>
                    <div>
                        <strong>Professional Growth</strong>
                        <p class="text-muted small mb-0">Build your reputation and expand your academic network.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <i class="bi bi-check-circle-fill text-primary fs-5 mt-1"></i>
                    <div>
                        <strong>Verified Profile</strong>
                        <p class="text-muted small mb-0">Showcase your qualifications on a trusted platform.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 cta-section">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Get Started?</h2>
        <p class="text-white-50 mb-4">Join ScholarRescue today and experience academic support you can trust.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg">Create Account</a>
            <a asp-controller="Home" asp-action="BecomeATutor" class="btn btn-outline-light btn-lg">Become a Tutor</a>
        </div>
    </div>
</section>

<style>
    .cta-section { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
</style>