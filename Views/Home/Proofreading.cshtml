@{
    ViewData["Title"] = "Proofreading Services";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Hero Section -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold text-white mb-3">Proofreading Services</h1>
                <p class="text-white-50 lead mb-0">
                    Final quality assurance for your academic documents, eliminating errors and ensuring professional presentation.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4 me-2">
                    <i class="bi bi-rocket-takeoff me-2"></i>Get Started
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Content Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <h2 class="fw-bold mb-4">Thorough Proofreading for Submission-Ready Documents</h2>
                <p class="text-muted lead mb-4">
                    Proofreading is the final quality assurance stage before submitting any academic document. Our proofreading service focuses on identifying and correcting surface-level errors that can reduce the professionalism and credibility of your work.
                </p>
                <p class="text-muted">
                    We carefully examine grammar, spelling, punctuation, capitalization, formatting inconsistencies, typographical mistakes, and citation presentation to ensure your document meets high academic standards. While editing focuses on improving structure and expression, proofreading concentrates on refining the final version of your paper before submission.
                </p>
                <p class="text-muted">
                    Our proofreaders review each document with meticulous attention to detail, helping students avoid avoidable mistakes that can negatively affect grades, evaluations, or publication decisions. This service is ideal for essays, coursework assignments, dissertations, theses, research papers, journal submissions, and professional academic documents.
                </p>
                <p class="text-muted">
                    By ensuring accuracy and consistency throughout your work, we help create a polished final product that reflects the quality of your research and effort. The result is a professional document that is ready for submission with confidence.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="py-5" style="background:var(--bg-main);">
    <div class="container">
        <h2 class="fw-bold text-center mb-5">Why Choose Our Proofreading Service</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-check2-circle fs-4 text-warning"></i>
                        </div>
                        <h6 class="fw-bold">Error Elimination</h6>
                        <p class="text-muted small mb-0">Meticulous correction of grammar, spelling, punctuation, and typographical errors.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-eye fs-4 text-primary"></i>
                        </div>
                        <h6 class="fw-bold">Attention to Detail</h6>
                        <p class="text-muted small mb-0">Every document is reviewed with meticulous care for maximum accuracy.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center p-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                            <i class="bi bi-file-earmark-check fs-4 text-success"></i>
                        </div>
                        <h6 class="fw-bold">Submission Ready</h6>
                        <p class="text-muted small mb-0">A polished, professional document ready for submission with confidence.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 cta-section">
    <div class="container text-center">
        <h2 class="fw-bold text-white mb-3">Ready to Perfect Your Document?</h2>
        <p class="text-white-50 mb-4">Ensure your academic work is error-free and professionally presented before submission.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Get Started
            </a>
            <a asp-controller="Home" asp-action="OrderNow" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-rocket-takeoff me-2"></i>Request Support
            </a>
            <a asp-controller="Account" asp-action="Register" asp-route-userType="Writer" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-person-plus me-2"></i>Register as Tutor
            </a>
        </div>
    </div>
</section>

<style>
    .cta-section { background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
</style>