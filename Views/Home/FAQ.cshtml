@{
    ViewData["Title"] = "FAQ";
    Layout = "~/Views/Shared/_Layout.Public.cshtml";
}

<!-- Page Header -->
<section class="py-5" style="background:linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);">
    <div class="container">
        <h1 class="display-5 fw-bold text-white">Frequently Asked Questions</h1>
        <p class="text-white-50 lead mb-2">Find answers to common questions about ScholarRescue</p>
        <div class="row">
            <div class="col-lg-6">
                <input type="text" id="faqSearch" class="form-control form-control-lg" placeholder="Search FAQs..." onkeyup="filterFAQs()" />
            </div>
        </div>
    </div>
</section>

<!-- FAQ Content -->
<section class="py-5">
    <div class="container">
        <!-- Pricing -->
        <h3 class="fw-bold mb-3"><i class="bi bi-tag text-primary me-2"></i>Pricing</h3>
        <div class="accordion mb-5" id="faqPricing">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#p1">
                        How is pricing determined?
                    </button>
                </h2>
                <div id="p1" class="accordion-collapse collapse show" data-bs-parent="#faqPricing">
                    <div class="accordion-body text-muted">Pricing is based on the type of service, academic level, complexity, and deadline. You'll see a transparent price breakdown before submitting your order.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#p2">
                        Are there any hidden fees?
                    </button>
                </h2>
                <div id="p2" class="accordion-collapse collapse" data-bs-parent="#faqPricing">
                    <div class="accordion-body text-muted">No. The price you see at checkout is the total price you'll pay. There are no hidden fees or surprise charges.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#p3">
                        Can I get a discount?
                    </button>
                </h2>
                <div id="p3" class="accordion-collapse collapse" data-bs-parent="#faqPricing">
                    <div class="accordion-body text-muted">We occasionally offer promotions and discounts for returning customers. Subscribe to our newsletter to stay updated on special offers.</div>
                </div>
            </div>
        </div>

        <!-- Orders -->
        <h3 class="fw-bold mb-3"><i class="bi bi-file-earmark-text text-primary me-2"></i>Orders</h3>
        <div class="accordion mb-5" id="faqOrders">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#o1">
                        How do I place an order?
                    </button>
                </h2>
                <div id="o1" class="accordion-collapse collapse show" data-bs-parent="#faqOrders">
                    <div class="accordion-body text-muted">After creating an account, navigate to "Create Order" from your dashboard. Fill in the order details including subject, academic level, deadline, and instructions. Review the price and submit.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#o2">
                        Can I track my order?
                    </button>
                </h2>
                <div id="o2" class="accordion-collapse collapse" data-bs-parent="#faqOrders">
                    <div class="accordion-body text-muted">Yes. You can track your order status in real-time through your dashboard. You'll also receive notifications when there are updates.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#o3">
                        What if I need to modify my order?
                    </button>
                </h2>
                <div id="o3" class="accordion-collapse collapse" data-bs-parent="#faqOrders">
                    <div class="accordion-body text-muted">You can communicate with your assigned tutor through the messaging system to provide additional instructions or clarifications during the order process.</div>
                </div>
            </div>
        </div>

        <!-- Messaging -->
        <h3 class="fw-bold mb-3"><i class="bi bi-chat-dots text-primary me-2"></i>Messaging</h3>
        <div class="accordion mb-5" id="faqMessaging">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#m1">
                        How does messaging work?
                    </button>
                </h2>
                <div id="m1" class="accordion-collapse collapse" data-bs-parent="#faqMessaging">
                    <div class="accordion-body text-muted">Once an order is assigned, both you and the tutor can communicate through our secure messaging system. You can share files, ask questions, and receive updates.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#m2">
                        Is messaging secure?
                    </button>
                </h2>
                <div id="m2" class="accordion-collapse collapse" data-bs-parent="#faqMessaging">
                    <div class="accordion-body text-muted">Yes. All messages are encrypted and only accessible to the participants of the conversation. Your communication is private and secure.</div>
                </div>
            </div>
        </div>

        <!-- Tutor Applications -->
        <h3 class="fw-bold mb-3"><i class="bi bi-person-check text-primary me-2"></i>Tutor Applications</h3>
        <div class="accordion mb-5" id="faqTutor">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#t1">
                        How do I apply to become a tutor?
                    </button>
                </h2>
                <div id="t1" class="accordion-collapse collapse" data-bs-parent="#faqTutor">
                    <div class="accordion-body text-muted">Register an account, then submit a tutor application through your profile. Provide your qualifications, experience, and areas of expertise. Our team will review your application.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#t2">
                        How long does approval take?
                    </button>
                </h2>
                <div id="t2" class="accordion-collapse collapse" data-bs-parent="#faqTutor">
                    <div class="accordion-body text-muted">The review process typically takes 3-5 business days. You'll receive email notifications at each stage of the review process.</div>
                </div>
            </div>
        </div>

        <!-- Wallets -->
        <h3 class="fw-bold mb-3"><i class="bi bi-wallet2 text-primary me-2"></i>Wallets</h3>
        <div class="accordion mb-5" id="faqWallet">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#w1">
                        How does the wallet work?
                    </button>
                </h2>
                <div id="w1" class="accordion-collapse collapse" data-bs-parent="#faqWallet">
                    <div class="accordion-body text-muted">Tutors have a wallet that tracks their earnings. When an order is completed and approved, the payment is credited to your wallet balance.</div>
                </div>
            </div>
        </div>

        <!-- Payouts -->
        <h3 class="fw-bold mb-3"><i class="bi bi-cash-stack text-primary me-2"></i>Payouts</h3>
        <div class="accordion mb-5" id="faqPayout">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#pay1">
                        How do I request a payout?
                    </button>
                </h2>
                <div id="pay1" class="accordion-collapse collapse" data-bs-parent="#faqPayout">
                    <div class="accordion-body text-muted">Navigate to the Payouts section in your dashboard. Enter the amount you wish to withdraw and select your payment method. Payouts are processed within the current payout window.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#pay2">
                        What payout methods are available?
                    </button>
                </h2>
                <div id="pay2" class="accordion-collapse collapse" data-bs-parent="#faqPayout">
                    <div class="accordion-body text-muted">We support bank transfers and mobile money. Configure your preferred payment method in the Payment Details section of your dashboard.</div>
                </div>
            </div>
        </div>

        <!-- Security -->
        <h3 class="fw-bold mb-3"><i class="bi bi-shield-lock text-primary me-2"></i>Security</h3>
        <div class="accordion mb-5" id="faqSecurity">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#s1">
                        Is my data secure?
                    </button>
                </h2>
                <div id="s1" class="accordion-collapse collapse" data-bs-parent="#faqSecurity">
                    <div class="accordion-body text-muted">Yes. We use industry-standard encryption and security practices to protect your personal data, communications, and financial information.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#s2">
                        Is my payment information safe?
                    </button>
                </h2>
                <div id="s2" class="accordion-collapse collapse" data-bs-parent="#faqSecurity">
                    <div class="accordion-body text-muted">Yes. Payment processing is handled through secure, PCI-compliant channels. We never store your full payment card details on our servers.</div>
                </div>
            </div>
        </div>

        <!-- Refunds -->
        <h3 class="fw-bold mb-3"><i class="bi bi-arrow-return-left text-primary me-2"></i>Refunds</h3>
        <div class="accordion mb-5" id="faqRefund">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#r1">
                        What is the refund policy?
                    </button>
                </h2>
                <div id="r1" class="accordion-collapse collapse" data-bs-parent="#faqRefund">
                    <div class="accordion-body text-muted">If you're not satisfied with the delivered work, you can request a revision or escalate the issue to our support team. Refund policies are outlined in our Terms of Service.</div>
                </div>
            </div>
        </div>

        <!-- Accounts -->
        <h3 class="fw-bold mb-3"><i class="bi bi-person-gear text-primary me-2"></i>Accounts</h3>
        <div class="accordion mb-5" id="faqAccounts">
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#a1">
                        How do I create an account?
                    </button>
                </h2>
                <div id="a1" class="accordion-collapse collapse" data-bs-parent="#faqAccounts">
                    <div class="accordion-body text-muted">Click the "Register" button on any page, fill in your details including name, email, and password. You'll be registered as a Client by default. You can later apply to become a Tutor.</div>
                </div>
            </div>
            <div class="accordion-item border-0 shadow-sm mb-3 rounded faq-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#a2">
                        Can I have both a client and tutor account?
                    </button>
                </h2>
                <div id="a2" class="accordion-collapse collapse" data-bs-parent="#faqAccounts">
                    <div class="accordion-body text-muted">Each account is associated with one primary role. If you want to both post and complete orders, you'll need to register separate accounts with different email addresses.</div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function filterFAQs() {
            var search = document.getElementById('faqSearch').value.toLowerCase();
            var items = document.querySelectorAll('.faq-item');
            items.forEach(function (item) {
                var text = item.textContent.toLowerCase();
                item.style.display = text.includes(search) ? '' : 'none';
            });
        }
    </script>
}