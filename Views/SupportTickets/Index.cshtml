@model List<ScholarRescue.Models.SupportTicket>
@using ScholarRescue.Models.Enums
@{ ViewData["Title"] = "Support Tickets"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-ticket me-2"></i>Support Tickets</h4>
        <p class="text-muted small mb-0">Create and track support requests across departments.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>New Ticket</a>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.DepartmentFilter == null ? "btn-primary" : "btn-outline-primary") rounded-pill">All</a>
    @foreach (SupportDepartment d in Enum.GetValues<SupportDepartment>())
    {
        <a asp-action="Index" asp-route-department="@d" class="btn btn-sm @(ViewBag.DepartmentFilter as SupportDepartment? == d ? "btn-primary" : "btn-outline-primary") rounded-pill">@d</a>
    }
</div>

@if (!Model.Any()) { <div class="text-center py-5"><i class="bi bi-ticket fs-1 text-muted"></i><p class="text-muted mt-2">No tickets found.</p></div> }
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light"><tr><th>#</th><th>Subject</th><th>Department</th><th>Status</th><th>Created</th><th class="text-end">Actions</th></tr></thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="fw-medium">@t.TicketNumber</td>
                            <td><a asp-action="Details" asp-route-id="@t.Id" class="text-decoration-none">@t.Subject</a></td>
                            <td><span class="badge bg-info bg-opacity-10 text-info">@t.Department</span></td>
                            <td>@{ var stBg = t.Status == TicketStatus.Open ? "danger" : t.Status == TicketStatus.PendingResponse ? "warning" : t.Status == TicketStatus.Resolved ? "success" : "secondary"; }<span class="badge bg-@stBg">@t.Status</span></td>
                            <td class="text-muted small">@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end"><a asp-action="Details" asp-route-id="@t.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-eye"></i></a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}