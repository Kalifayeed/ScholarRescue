@using ScholarRescue.Models.Enums
@{ ViewData["Title"] = "New Support Ticket"; }

<div class="mb-4">
    <h4 class="mb-1"><i class="bi bi-ticket me-2"></i>New Support Ticket</h4>
    <p class="text-muted small">Select the appropriate department for your request.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Subject <span class="text-danger">*</span></label>
                        <input name="subject" class="form-control" required maxlength="200" placeholder="Brief summary of your issue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Department <span class="text-danger">*</span></label>
                        <select name="department" class="form-select" required>
                            <option value="">-- Select --</option>
                            @foreach (SupportDepartment d in Enum.GetValues<SupportDepartment>())
                            { <option value="@d">@d</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Description <span class="text-danger">*</span></label>
                        <textarea name="description" class="form-control" rows="6" required placeholder="Detailed description of your issue..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Order ID (optional)</label>
                        <input name="orderId" type="number" class="form-control" min="1" placeholder="If this is about a specific order" />
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-send me-1"></i>Submit Ticket</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>