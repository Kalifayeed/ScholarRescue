@model ScholarRescue.Models.SupportTicket
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = $"Ticket {Model.TicketNumber}";
    var notes = ViewBag.Notes as List<ScholarRescue.Models.SupportTicketNote> ?? new();
    var attachments = ViewBag.Attachments as List<ScholarRescue.Models.SupportTicketAttachment> ?? new();
    bool isAdmin = ViewBag.IsAdmin as bool? ?? false;
}

<div class="mb-4">
    <nav aria-label="breadcrumb"><ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Tickets</a></li>
        <li class="breadcrumb-item active">@Model.TicketNumber</li>
    </ol></nav>
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
        <div>
            <h4 class="mb-1">@Model.Subject</h4>
            <p class="text-muted small mb-0">
                @Model.TicketNumber &middot; <span class="badge bg-info bg-opacity-10 text-info">@Model.Department</span>
                &middot; <span class="badge bg-@(Model.Status == TicketStatus.Open ? "danger" : Model.Status == TicketStatus.PendingResponse ? "warning" : Model.Status == TicketStatus.Resolved ? "success" : "secondary")">@Model.Status</span>
                &middot; Created @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm") by @(Model.Creator?.FirstName ?? "Unknown")
            </p>
        </div>
        @if (isAdmin)
        {
            <form asp-action="ChangeStatus" method="post" class="d-flex gap-1 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <select name="newStatus" class="form-select form-select-sm" style="width:auto;">
                    @foreach (TicketStatus s in Enum.GetValues<TicketStatus>())
                    { <option value="@s" selected="@(s == Model.Status)">@s</option> }
                </select>
                <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
            </form>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <!-- Description -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold">Description</h6></div>
            <div class="card-body"><p class="mb-0">@Model.Description</p></div>
        </div>

        <!-- Notes -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-chat-dots me-1"></i>Notes</h6></div>
            <div class="card-body">
                @if (!notes.Any()) { <p class="text-muted small mb-0">No notes yet.</p> }
                else {
                    <div class="list-group list-group-flush">
                        @foreach (var n in notes)
                        {
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between">
                                    <small class="fw-medium">@(n.Author?.FirstName ?? "Unknown")</small>
                                    <small class="text-muted">@n.CreatedAt.ToString("MMM dd HH:mm")</small>
                                </div>
                                <p class="small mb-0 mt-1">@n.Content</p>
                                @if (n.IsInternal) { <span class="badge bg-warning bg-opacity-10 text-warning mt-1">Internal</span> }
                            </div>
                        }
                    </div>
                }
                <form asp-action="AddNote" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-2">
                        <textarea name="content" class="form-control" rows="2" placeholder="Add a note..." required></textarea>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-plus me-1"></i>Add Note</button>
                        @if (isAdmin)
                        {
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" id="isInternal" name="isInternal" value="true" checked />
                                <label class="form-check-label small" for="isInternal">Internal note</label>
                            </div>
                        }
                        <input type="hidden" name="isInternal" value="false" />
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Meta -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold">Details</h6></div>
            <div class="card-body small">
                <div class="mb-2"><strong>Department:</strong> @Model.Department</div>
                <div class="mb-2"><strong>Status:</strong> @Model.Status</div>
                <div class="mb-2"><strong>Created:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                @if (Model.ResolvedAt.HasValue) { <div class="mb-2"><strong>Resolved:</strong> @Model.ResolvedAt.Value.ToString("MMM dd, yyyy")</div> }
                @if (Model.OrderId.HasValue) { <div><strong>Order:</strong> #@Model.OrderId.Value</div> }
            </div>
        </div>

        <!-- Attachments -->
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-paperclip me-1"></i>Attachments</h6></div>
            <div class="card-body">
                @if (!attachments.Any()) { <p class="text-muted small mb-0">No attachments.</p> }
                else {
                    <ul class="list-unstyled small mb-0">
                        @foreach (var a in attachments)
                        {
                            <li><a href="@a.FilePath" target="_blank"><i class="bi bi-file-earmark me-1"></i>@a.FileName</a> <span class="text-muted">(@((a.FileSizeBytes/1024.0).ToString("F1")) KB)</span></li>
                        }
                    </ul>
                }
                <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="file" name="file" class="form-control form-control-sm" required />
                    <button type="submit" class="btn btn-sm btn-outline-primary mt-2"><i class="bi bi-upload me-1"></i>Upload</button>
                </form>
            </div>
        </div>
    </div>
</div>