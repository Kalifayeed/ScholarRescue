@model ScholarRescue.Models.Enums.WriterAvailabilityStatus
@using ScholarRescue.Models.Enums
@{
    string color = Model switch
    {
        WriterAvailabilityStatus.Available => "success",
        WriterAvailabilityStatus.Busy => "warning",
        WriterAvailabilityStatus.Full => "danger",
        WriterAvailabilityStatus.Suspended => "dark",
        WriterAvailabilityStatus.Offline => "secondary",
        _ => "secondary"
    };
    string icon = Model switch
    {
        WriterAvailabilityStatus.Available => "bi-check-circle",
        WriterAvailabilityStatus.Busy => "bi-clock",
        WriterAvailabilityStatus.Full => "bi-x-circle",
        WriterAvailabilityStatus.Suspended => "bi-lock",
        WriterAvailabilityStatus.Offline => "bi-power",
        _ => "bi-question-circle"
    };
}

<span class="badge bg-@color bg-opacity-10 text-@color" title="Writer availability: @Model">
    <i class="bi @icon me-1"></i>@Model
</span>
