<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ScholarRescue</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/public.css" asp-append-version="true" />
</head>
<body class="public-body">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white public-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-mortarboard-fill"></i></span>
                    ScholarRescue
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#publicNavbar"
                        aria-controls="publicNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="publicNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Opportunities">Opportunities</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="FAQ">FAQ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Reviews">Reviews</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Blog">Blog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-muted small" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-accent px-4" asp-action="OrderNow" asp-controller="Home">
                                <i class="bi bi-lightning-charge-fill me-1"></i> Request Support
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-primary btn-sm px-3" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-shrink-0">
        @RenderBody()
    </main>

    <footer class="public-footer">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="d-flex align-items-center mb-3">
                        <span class="brand-icon me-2"><i class="bi bi-mortarboard-fill"></i></span>
                        <h5 class="mb-0 fw-bold text-white">ScholarRescue</h5>
                    </div>
                    <p class="text-white-50 small">
                        Academic Support Platform connecting students with qualified tutors, research mentors, editors, and academic professionals.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-white-50"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-twitter-x fs-5"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-linkedin fs-5"></i></a>
                        <a href="#" class="text-white-50"><i class="bi bi-instagram fs-5"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold text-white mb-3">Platform</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="About" class="text-white-50 small">About Us</a></li>
                        <li class="mb-2"><a asp-controller="Account" asp-action="Register" class="text-white-50 small">Apply as Tutor</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Opportunities" class="text-white-50 small">Opportunities</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Blog" class="text-white-50 small">Blog</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold text-white mb-3">Support</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="FAQ" class="text-white-50 small">FAQ</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact" class="text-white-50 small">Contact Us</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Reviews" class="text-white-50 small">Reviews</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold text-white mb-3">Legal</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy" class="text-white-50 small">Privacy Policy</a></li>
                        <li class="mb-2"><a href="#" class="text-white-50 small">Terms of Service</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="fw-bold text-white mb-3">Services</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2"><span class="text-white-50 small">Tutoring</span></li>
                        <li class="mb-2"><span class="text-white-50 small">Research Guidance</span></li>
                        <li class="mb-2"><span class="text-white-50 small">Editing</span></li>
                        <li class="mb-2"><span class="text-white-50 small">Proofreading</span></li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary" />
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                <div class="text-white-50 small">
                    &copy; 2026 <strong class="text-white">ScholarRescue</strong> &mdash; Academic Support Platform
                </div>
                <div class="text-white-50 small">
                    Tutoring &bull; Research Guidance &bull; Editing &bull; Proofreading &bull; Formatting &bull; Citation
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>