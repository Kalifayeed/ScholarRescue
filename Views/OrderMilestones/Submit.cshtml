@using ScholarRescue.Models
@using ScholarRescue.Models.Enums
@{
    var milestone = ViewBag.Milestone as OrderMilestone;
    var order = ViewBag.Order as TutoringRequest;
    var files = ViewBag.Files as List<OrderMilestoneFile> ?? new List<OrderMilestoneFile>();
    ViewData["Title"] = $"Submit Milestone: {milestone?.Title}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-action="Timeline" asp-route-orderId="@milestone?.OrderId" class="text-decoration-none">Timeline</a></li>
            <li class="breadcrumb-item active">Submit</li>
        </ol>
    </nav>
    <h4 class="mb-1"><i class="bi bi-cloud-upload me-2"></i>Submit Files for Milestone</h4>
    <p class="text-muted small mb-0">
        <strong>@milestone?.Title</strong> &middot; @milestone?.Pages pages
        &middot; Deadline @milestone?.Deadline.ToString("MMM dd, yyyy")
    </p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        @if (files.Any())
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fw-semibold">Already Uploaded</h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var f in files)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <a href="@f.FilePath" target="_blank"><i class="bi bi-paperclip me-1"></i>@f.FileName</a>
                                <span class="text-muted small ms-2">(@((f.FileSizeBytes / 1024.0).ToString("F1")) KB &middot; @f.UploadedAt.ToString("MMM dd HH:mm"))</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        }

        <form asp-action="Submit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@milestone?.Id" />

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fw-semibold">Upload New Files</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Files <span class="text-danger">*</span></label>
                        <input type="file" name="files" multiple required
                               accept=".pdf,.doc,.docx,.zip"
                               class="form-control" />
                        <span class="text-muted small">PDF, DOC, DOCX, or ZIP. Max 25MB per file.</span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Notes (optional)</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Anything the client should know about these files..."></textarea>
                    </div>
                </div>
            </div>

            <div class="alert alert-info small">
                <i class="bi bi-info-circle me-1"></i>
                <strong>What happens next:</strong> The client will be notified. Once they approve, the milestone earnings
                (90% of proportional order budget) will be credited to your wallet.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-cloud-upload me-1"></i>Submit Files
                </button>
                <a asp-action="Timeline" asp-route-orderId="@milestone?.OrderId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
