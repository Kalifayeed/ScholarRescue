@model ScholarRescue.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">
                <i class="bi bi-speedometer2"></i> Admin Dashboard
            </h1>
            <small class="text-muted">Platform administration and management center</small>
        </div>
        <span class="badge bg-dark fs-6 py-2 px-3 rounded-pill">
            <i class="bi bi-shield-check"></i> @Model.CurrentUserRole
        </span>
    </div>

    @* Statistics Overview *@
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Users</h6>
                            <h2 class="fw-bold mb-0 text-primary">@Model.TotalUsers</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-people fs-3 text-primary"></i>
                        </div>
                    </div>
                    <div class="mt-3 d-flex flex-wrap gap-1">
                        <span class="badge bg-info rounded-pill">@Model.TotalClients Clients</span>
                        <span class="badge bg-warning rounded-pill">@Model.TotalWriters Writers</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Orders</h6>
                            <h2 class="fw-bold mb-0 text-warning">@Model.TotalOrders</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-file-earmark-text fs-3 text-warning"></i>
                        </div>
                    </div>
                    <div class="mt-3 d-flex flex-wrap gap-1">
                        <span class="badge bg-info rounded-pill">@Model.PendingOrders Pending</span>
                        <span class="badge bg-primary rounded-pill">@Model.InProgressOrders Active</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Revenue</h6>
                            <h2 class="fw-bold mb-0 text-success">@Model.TotalRevenue.ToString("C")</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cash-coin fs-3 text-success"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted small">From completed & delivered orders</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Pending Applications</h6>
                            <h2 class="fw-bold mb-0 text-warning">@Model.PendingApplications</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-person-check fs-3 text-warning"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <span class="text-muted small">Writer applications awaiting review</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Support Tickets Summary *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning bg-opacity-10 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-ticket-perforated"></i> Support Tickets</h6>
                    <a asp-controller="Messages" asp-action="Index" class="btn btn-sm btn-outline-warning">View All</a>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col">
                            <h4 class="fw-bold text-danger">@Model.OpenTickets</h4>
                            <small class="text-muted">Open</small>
                        </div>
                        <div class="col">
                            <h4 class="fw-bold text-warning">@Model.PendingTickets</h4>
                            <small class="text-muted">Pending</small>
                        </div>
                        <div class="col">
                            <h4 class="fw-bold text-info">@Model.InProgressTickets</h4>
                            <small class="text-muted">In Progress</small>
                        </div>
                        <div class="col">
                            <h4 class="fw-bold text-success">@Model.ResolvedTickets</h4>
                            <small class="text-muted">Resolved</small>
                        </div>
                        <div class="col">
                            <h4 class="fw-bold text-secondary">@Model.TotalTickets</h4>
                            <small class="text-muted">Total</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Recent Conversations *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Recent Conversations</h5>
                    <a asp-controller="Admin" asp-action="Conversations" class="btn btn-light btn-sm">
                        <i class="bi bi-chat-square-text"></i> All Conversations
                    </a>
                </div>
                <div class="card-body" id="recentConversationsWidget">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Loading conversations...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Admin Navigation Cards *@
    <h5 class="mb-3 fw-bold"><i class="bi bi-grid-3x3-gap-fill"></i> Administration Modules</h5>
    <div class="row g-3 mb-4">
        <div class="col-xl-4 col-md-6">
            <a asp-action="Users" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-people fs-1 text-primary"></i>
                        </div>
                        <h5 class="fw-bold text-dark">User Management</h5>
                        <p class="text-muted small mb-0">Manage users, assign roles, activate/deactivate accounts</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-primary rounded-pill">Manage <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-controller="Orders" asp-action="Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-file-earmark-text fs-1 text-warning"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Orders Management</h5>
                        <p class="text-muted small mb-0">View, edit, assign, and manage all platform orders</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-warning text-dark rounded-pill">Manage <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-action="WriterApplications" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-person-check fs-1 text-success"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Writer Applications</h5>
                        <p class="text-muted small mb-0">Review and approve writer applications and qualifications</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-success rounded-pill">Manage <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-action="AuditLogs" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-info bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-journal-text fs-1 text-info"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Audit Logs</h5>
                        <p class="text-muted small mb-0">View system audit trail and administrative actions</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-info text-dark rounded-pill">View <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-action="OrderManagement" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-cart-check fs-1 text-danger"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Order Management</h5>
                        <p class="text-muted small mb-0">View, assign writers, manage applicants, and track progress</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-danger rounded-pill">Manage <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-action="Payments" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-secondary bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-credit-card fs-1 text-secondary"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Payments Management</h5>
                        <p class="text-muted small mb-0">Track payments, process payouts, manage invoices</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-secondary rounded-pill">Manage <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-xl-4 col-md-6">
            <a asp-action="Reports" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 admin-nav-card">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-dark bg-opacity-10 d-inline-flex p-3 mb-3">
                            <i class="bi bi-graph-up fs-1 text-dark"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Reports & Analytics</h5>
                        <p class="text-muted small mb-0">Generate platform reports, analytics, and data exports</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-end p-2">
                        <span class="badge bg-dark rounded-pill">View <i class="bi bi-arrow-right"></i></span>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            loadRecentConversations();
            setupSignalR();
        });

        function loadRecentConversations() {
            var widget = document.getElementById('recentConversationsWidget');
            if (!widget) return;

            fetch('/Messages/Recent?take=5')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data || !data.success) {
                        widget.innerHTML = '<div class="text-center py-3 text-muted"><p class="small mb-0">Could not load conversations.</p></div>';
                        return;
                    }
                    if (!data.conversations || data.conversations.length === 0) {
                        widget.innerHTML = '<div class="text-center py-3 text-muted"><i class="bi bi-inbox d-block mb-1" style="font-size:2rem;"></i><p class="small mb-0">No recent conversations.</p></div>';
                        return;
                    }
                    var html = '<div class="list-group list-group-flush">';
                    data.conversations.forEach(function (c) {
                        var time = formatRelativeLocal(c.lastMessageDate);
                        var unreadBadge = c.unreadCount > 0 ? '<span class="badge bg-danger rounded-pill ms-auto">' + c.unreadCount + '</span>' : '';
                        var online = c.isOtherPartyOnline
                            ? '<span class="text-success"><i class="bi bi-circle-fill" style="font-size:0.5rem;"></i></span>'
                            : '<span class="text-muted"><i class="bi bi-circle" style="font-size:0.5rem;"></i></span>';
                        html += '<a href="/Messages/Conversation/' + c.conversationId + '" class="list-group-item list-group-item-action d-flex align-items-start py-2 px-3">' +
                            '<div class="flex-grow-1 min-w-0">' +
                            '<div class="d-flex justify-content-between align-items-center">' +
                            '<strong class="text-truncate small">' + escapeHtml(c.otherPartyName || c.orderNumber) + '</strong>' +
                            '<small class="text-muted ms-2 flex-shrink-0">' + time + '</small>' +
                            '</div>' +
                            '<div class="small text-muted text-truncate">' +
                            '<span class="fw-medium">' + escapeHtml(c.orderNumber) + ':</span> ' +
                            escapeHtml(c.lastMessagePreview || '') +
                            '</div>' +
                            '<div class="d-flex align-items-center gap-1 mt-1">' +
                            online +
                            '<small class="text-muted" style="font-size:0.7rem;">' + escapeHtml(c.otherPartyName || '') + '</small>' +
                            '</div>' +
                            '</div>' +
                            unreadBadge +
                            '</a>';
                    });
                    html += '</div>';
                    widget.innerHTML = html;
                })
                .catch(function () {
                    widget.innerHTML = '<div class="text-center py-3 text-muted"><p class="small mb-0">Error loading conversations.</p></div>';
                });
        }

        function setupSignalR() {
            try {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub')
                    .build();
                connection.on('ReceiveMessage', function () {
                    setTimeout(loadRecentConversations, 500);
                });
                connection.on('ReceiveNotification', function () {
                    setTimeout(loadRecentConversations, 500);
                });
                connection.start().catch(function () {});
            } catch (e) {}
        }

        function formatRelativeLocal(utcStr) {
            try {
                var d = new Date(utcStr);
                var now = new Date();
                var diffMs = now - d;
                var diffMin = Math.floor(diffMs / 60000);
                if (diffMin < 1) return 'Just now';
                if (diffMin < 60) return diffMin + 'm ago';
                var diffHr = Math.floor(diffMin / 60);
                if (diffHr < 24) return diffHr + 'h ago';
                var diffDay = Math.floor(diffHr / 24);
                if (diffDay < 7) return diffDay + 'd ago';
                return d.toLocaleDateString();
            } catch (e) { return ''; }
        }

        function escapeHtml(s) {
            if (s == null) return '';
            return String(s).replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>').replace(/"/g,'"').replace(/'/g,'&#039;');
        }
    </script>
    <style>
        .admin-nav-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
        }
        .admin-nav-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
        }
        .admin-nav-card a {
            color: inherit;
        }
    </style>
}