@model List<ScholarRescue.Models.WriterRanking>
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = "Writer Rankings";
    var currentFilter = ViewBag.CurrentFilter as WriterRank?;
    var criteria = ViewBag.Criteria as IReadOnlyList<RankCriteria> ?? new List<RankCriteria>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-trophy me-2"></i>Writer Rankings</h4>
        <p class="text-muted mb-0 small">Auto-promoted based on completed orders, ratings, and quality metrics. Admins can override.</p>
    </div>
</div>

<!-- Promotion Criteria -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-1"></i>Auto-Promotion Criteria</h6>
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4">
                <div class="border rounded p-2 text-center">
                    <span class="badge bg-primary bg-opacity-10 text-primary">Regular</span>
                    <div class="small mt-1">10+ orders, 4.5+ rating</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-2 text-center">
                    <span class="badge bg-info bg-opacity-10 text-info">Senior</span>
                    <div class="small mt-1">50+ orders, 4.7+ rating</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-2 text-center">
                    <span class="badge bg-warning bg-opacity-10 text-warning">Elite</span>
                    <div class="small mt-1">150+ orders, 4.8+ rating</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter pills -->
<div class="d-flex flex-wrap gap-2 mb-3">
    <a asp-action="WriterRankings" class="btn btn-sm @(currentFilter == null ? "btn-primary" : "btn-outline-primary") rounded-pill">All</a>
    @foreach (WriterRank r in Enum.GetValues<WriterRank>())
    {
        <a asp-action="WriterRankings" asp-route-filterRank="@r"
           class="btn btn-sm @(currentFilter == r ? "btn-primary" : "btn-outline-primary") rounded-pill">
            @r
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-trophy fs-1 text-muted"></i>
        <p class="text-muted mt-2">No writer rankings yet. Rankings are created when writers complete their first order.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Writer</th>
                        <th>Current Rank</th>
                        <th class="text-center">Orders</th>
                        <th class="text-center">Rating</th>
                        <th class="text-center">Revisions</th>
                        <th class="text-center">Disputes</th>
                        <th class="text-center">On-Time</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-medium">@(r.Writer != null ? r.Writer.FirstName + " " + r.Writer.LastName : "(deleted)")</div>
                                <div class="text-muted small">@(r.Writer?.Email ?? r.WriterId)</div>
                            </td>
                            <td>
                                <partial name="_RankBadge" model="r.CurrentRank" />
                            </td>
                            <td class="text-center fw-medium">@r.CompletedOrders</td>
                            <td class="text-center">
                                @if (r.TotalRatings > 0)
                                {
                                    <span class="fw-medium">@r.AverageRating.ToString("F2")</span>
                                    <span class="text-muted small">(@r.TotalRatings)</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">@r.OrdersWithRevisions <span class="text-muted small">(@(r.RevisionRate * 100).ToString("F0")%)</span></td>
                            <td class="text-center">@r.DisputedOrders <span class="text-muted small">(@(r.DisputeRate * 100).ToString("F0")%)</span></td>
                            <td class="text-center">@r.OnTimeDeliveries <span class="text-muted small">(@(r.OnTimeDeliveryRate * 100).ToString("F0")%)</span></td>
                            <td>
                                @if (r.IsOverridden)
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning">Manual</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success">Auto</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                            data-bs-target="#overrideModal-@r.Id">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <form asp-action="RecomputeWriterRank" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="writerId" value="@r.WriterId" />
                                        <button type="submit" class="btn btn-outline-info btn-sm" title="Re-evaluate">
                                            <i class="bi bi-arrow-clockwise"></i>
                                        </button>
                                    </form>
                                    @if (r.IsOverridden)
                                    {
                                        <form asp-action="ClearWriterRankOverride" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="writerId" value="@r.WriterId" />
                                            <button type="submit" class="btn btn-outline-success btn-sm" title="Clear override">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>

                        <!-- Override Modal -->
                        <div class="modal fade" id="overrideModal-@r.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="OverrideWriterRank" method="post">
                                        @Html.AntiForgeryToken()
                                        <div class="modal-header">
                                            <h5 class="modal-title">Override Rank for @(r.Writer?.FirstName ?? "Writer")</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <input type="hidden" name="writerId" value="@r.WriterId" />
                                            <div class="mb-3">
                                                <label class="form-label fw-medium">New Rank</label>
                                                <select name="newRank" class="form-select">
                                                    @foreach (WriterRank rank in Enum.GetValues<WriterRank>())
                                                    {
                                                        <option value="@rank" selected="@(rank == r.CurrentRank)">@rank</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label fw-medium">Notes (optional)</label>
                                                <textarea name="notes" class="form-control" rows="3" placeholder="Reason for override..."></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Override Rank</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
