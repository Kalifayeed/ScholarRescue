@model ScholarRescue.ViewModels.Messaging.ConversationIndexViewModel

@{
    ViewData["Title"] = "All Conversations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-globe"></i> All Conversations
        </h1>
        <div>
            <span class="badge bg-primary fs-6 py-2 px-3 rounded-pill">
                <i class="bi bi-shield-check"></i> Admin View
            </span>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Conversations" method="get" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label fw-bold"><i class="bi bi-search"></i> Search Conversations</label>
                    <div class="input-group">
                        <input type="text" name="search" class="form-control"
                               placeholder="Search by order number, title, or participant name..."
                               value="@Model.SearchTerm" />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <a asp-action="Conversations" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Clear
                            </a>
                        }
                    </div>
                </div>
                <div class="col-md-2">
                    <small class="text-muted d-block">
                        Total: @ViewBag.TotalPages pages
                    </small>
                </div>
            </form>
        </div>
    </div>

    <!-- Conversations List -->
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-chat-dots"></i> Conversations</h5>
            <span class="badge bg-light text-dark">@Model.Conversations.Count conversations</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Conversations.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-2"></i>
                    <h6>No conversations found</h6>
                    <p class="small mb-0">
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <text>No conversations match your search.</text>
                        }
                        else
                        {
                            <text>There are no active conversations on the platform.</text>
                        }
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order #</th>
                                <th>Order Title</th>
                                <th>Participants</th>
                                <th>Last Message</th>
                                <th>Last Activity</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var conv in Model.Conversations)
                            {
                                <tr>
                                    <td><strong>@conv.OrderNumber</strong></td>
                                    <td>
                                        <span title="@conv.OrderTitle">
                                            @(conv.OrderTitle.Length > 30 ? conv.OrderTitle[..30] + "..." : conv.OrderTitle)
                                        </span>
                                    </td>
                                    <td>
                                        <small>@conv.OtherPartyName</small>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @if (!string.IsNullOrEmpty(conv.LastMessagePreview))
                                            {
                                                @(conv.LastMessagePreview.Length > 50 ? conv.LastMessagePreview[..50] + "..." : conv.LastMessagePreview)
                                            }
                                            else
                                            {
                                                <em class="text-muted">No messages yet</em>
                                            }
                                        </small>
                                    </td>
                                    <td>
                                        <small class="text-muted" data-utc="@conv.LastMessageDate.ToString("o")">
                                            @conv.LastMessageDate.ToLocalTime().ToString("MMM dd, h:mm tt")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Messages" asp-action="Conversation" asp-route-id="@conv.Id"
                                           class="btn btn-sm btn-outline-primary" title="Open conversation">
                                            <i class="bi bi-chat"></i> Open
                                        </a>
                                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@conv.OrderId"
                                           class="btn btn-sm btn-outline-info" title="View order">
                                            <i class="bi bi-file-text"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Conversations"
                           asp-route-search="@ViewBag.SearchTerm"
                           asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script>
        // Convert UTC timestamps to local time
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-utc]').forEach(function (el) {
                try {
                    var d = new Date(el.dataset.utc);
                    var now = new Date();
                    var diffMs = now - d;
                    var diffMin = Math.floor(diffMs / 60000);
                    var display;
                    if (diffMin < 1) display = 'Just now';
                    else if (diffMin < 60) display = diffMin + 'm ago';
                    else if (diffMin < 1440) display = Math.floor(diffMin / 60) + 'h ago';
                    else if (diffMin < 10080) display = Math.floor(diffMin / 1440) + 'd ago';
                    else display = d.toLocaleDateString();
                    el.textContent = display;
                } catch (e) { }
            });
        });
    </script>
}