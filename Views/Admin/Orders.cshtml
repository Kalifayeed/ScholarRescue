@{
    ViewData["Title"] = "Orders Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Orders Management</h2>
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        <strong>Coming Soon:</strong> Full orders management interface with filtering, status updates, and assignment controls.
    </div>

    <div class="card">
        <div class="card-body text-center py-5">
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i>
                    <strong>Updated:</strong> Full order management is now available.
                    <a asp-action="OrderManagement" class="alert-link">Go to Order Management</a>
                </div>
                <i class="bi bi-cart-check fs-1 text-muted"></i>
                <h4 class="mt-3">Orders Management</h4>
                <p class="text-muted">Manage orders, assign writers, and track progress:</p>
                <ul class="list-unstyled text-start d-inline-block">
                    <li><i class="bi bi-check-circle text-success"></i> View all orders with status filtering</li>
                    <li><i class="bi bi-check-circle text-success"></i> View applicants per order</li>
                    <li><i class="bi bi-check-circle text-success"></i> Assign writers to pending orders</li>
                    <li><i class="bi bi-check-circle text-success"></i> Reject writer applications</li>
                    <li><i class="bi bi-check-circle text-success"></i> Reassign orders back to marketplace</li>
                    <li><i class="bi bi-check-circle text-success"></i> View order details</li>
                </ul>
                <a asp-action="OrderManagement" class="btn btn-primary mt-3">
                    <i class="bi bi-cart-check"></i> Manage Orders
                </a>
        </div>
    </div>
</div>