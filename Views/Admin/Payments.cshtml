@{
    ViewData["Title"] = "Payments Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Payments Management</h2>
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        <strong>Coming Soon:</strong> Payments management interface with transaction history, payouts, and financial reports.
    </div>

    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-credit-card fs-1 text-muted"></i>
            <h4 class="mt-3">Payments Management</h4>
            <p class="text-muted">This section will provide payment oversight including:</p>
            <ul class="list-unstyled text-start d-inline-block">
                <li><i class="bi bi-check-circle text-success"></i> View all transactions with filtering</li>
                <li><i class="bi bi-check-circle text-success"></i> Process writer payouts</li>
                <li><i class="bi bi-check-circle text-success"></i> Manage client refunds</li>
                <li><i class="bi bi-check-circle text-success"></i> Track payment gateway status</li>
                <li><i class="bi bi-check-circle text-success"></i> Generate financial reports</li>
            </ul>
        </div>
    </div>
</div>