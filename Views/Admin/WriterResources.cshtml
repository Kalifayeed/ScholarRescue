@model List<ScholarRescue.Models.WriterResource>
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = "Manage Writer Resources";
    var currentFilter = ViewBag.CurrentFilter as WriterResourceCategory?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1"><i class="bi bi-book me-2"></i>Manage Writer Resources</h4>
        <p class="text-muted mb-0 small">Create, edit, and manage content for the Writer Knowledge Center.</p>
    </div>
    <a asp-action="WriterResourceCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>New Resource
    </a>
</div>

<!-- Category Filter -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="text-muted small fw-medium me-1">Filter:</span>
            <a asp-action="WriterResources" class="btn btn-sm @(currentFilter == null ? "btn-primary" : "btn-outline-primary") rounded-pill">All</a>
            @foreach (WriterResourceCategory cat in Enum.GetValues<WriterResourceCategory>())
            {
                <a asp-action="WriterResources" asp-route-category="@cat"
                   class="btn btn-sm @(currentFilter == cat ? "btn-primary" : "btn-outline-primary") rounded-pill">
                    @cat
                </a>
            }
        </div>
    </div>
</div>

<!-- Resources Table -->
@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-book fs-1 text-muted"></i>
        <p class="text-muted mt-2">No resources found.</p>
        <a asp-action="WriterResourceCreate" class="btn btn-primary btn-sm">Create First Resource</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Sub-Category</th>
                        <th>Sort</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">
                                <a asp-action="WriterResourceEdit" asp-route-id="@item.Id" class="text-decoration-none">
                                    @item.Title
                                </a>
                            </td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@item.Category</span></td>
                            <td class="text-muted small">@(item.SubCategory ?? "—")</td>
                            <td class="text-muted">@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary">Draft</span>
                                }
                            </td>
                            <td class="text-muted small">@item.UpdatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="WriterResourceEdit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="WriterResourceToggleActive" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-@(item.IsActive ? "warning" : "success") btn-sm" title="@(item.IsActive ? "Deactivate" : "Activate")">
                                            <i class="bi bi-@(item.IsActive ? "eye-slash" : "eye")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="WriterResourceDelete" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this resource?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}