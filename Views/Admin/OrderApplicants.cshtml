@model List<ScholarRescue.Models.OrderApplication>
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = "Order Applicants";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var order = ViewBag.Order as ScholarRescue.Models.TutoringRequest;
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-people"></i> Applicants for @order?.OrderNumber</h2>
            <small class="text-muted">@order?.Title</small>
        </div>
        <div>
            <a asp-action="OrderManagement" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Orders
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Order Summary *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <small class="text-muted d-block">Status</small>
                    <span class="badge bg-primary">@order?.Status</span>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Client</small>
                    <strong>@order?.Client?.FirstName @order?.Client?.LastName</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Budget</small>
                    <strong>@order?.Budget.ToString("C")</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Deadline</small>
                    <span>@order?.Deadline.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            </div>
        </div>
    </div>

    @* Current Assignment Status *@
    @if (order?.AssignedWriter != null)
    {
        <div class="alert alert-info mb-4">
            <i class="bi bi-info-circle"></i>
            Currently assigned to <strong>@order.AssignedWriter.FirstName @order.AssignedWriter.LastName</strong>
            <form asp-action="ReassignOrder" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@order.Id" />
                <button type="submit" class="btn btn-sm btn-outline-warning ms-2"
                        onclick="return confirm('Remove this writer and return the order to marketplace?');">
                    <i class="bi bi-arrow-return-left"></i> Remove & Reassign
                </button>
            </form>
        </div>
    }

    @* Automated Writer Recommendations *@
    @{
        var recommendations = ViewBag.Recommendations as List<ScholarRescue.Services.WriterRecommendation>;
    }
    @if (recommendations != null && recommendations.Any() && order?.AssignedWriter == null)
    {
        <div class="card border-0 shadow-sm mb-4 border-start border-4 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-stars me-2"></i>Automated Writer Recommendations</h5>
                <span class="badge bg-light text-primary">AI-Powered Matching</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Writer</th>
                                <th>Rank</th>
                                <th>Score</th>
                                <th>Subject</th>
                                <th>Capacity</th>
                                <th>Quality</th>
                                <th>Orders</th>
                                <th>Rating</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var rank = 1;
                                var alreadyAppliedIds = Model.Select(a => a.WriterId).ToHashSet();
                            }
                            @foreach (var rec in recommendations)
                            {
                                var isApplied = alreadyAppliedIds.Contains(rec.WriterId);
                                var capBadge = rec.CapacityPercent >= 80 ? "bg-danger" : rec.CapacityPercent >= 60 ? "bg-warning text-dark" : "bg-success";
                                var qualBadge = rec.QualityScore >= 80 ? "bg-success" : rec.QualityScore >= 60 ? "bg-info" : "bg-warning text-dark";
                                <tr class="@(rec.IsRecommended ? "table-success" : "")">
                                    <td>@(rank++)</td>
                                    <td>
                                        <strong>@rec.WriterName</strong>
                                        @if (rec.IsRecommended)
                                        {
                                            <span class="badge bg-success ms-1"><i class="bi bi-check-circle"></i> Recommended</span>
                                        }
                                        @if (isApplied)
                                        {
                                            <span class="badge bg-info ms-1">Applied</span>
                                        }
                                    </td>
                                    <td><span class="badge bg-secondary">@rec.RankName</span></td>
                                    <td><strong>@rec.RecommendationScore.ToString("F1")</strong></td>
                                    <td>
                                        @if (rec.SubjectMatch)
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Match</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No match</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height: 6px; max-width: 60px;">
                                                <div class="progress-bar @capBadge" role="progressbar" style="width: @rec.CapacityPercent%"></div>
                                            </div>
                                            <span class="small">@rec.ActiveOrders/@rec.MaxOrders</span>
                                        </div>
                                    </td>
                                    <td><span class="badge @qualBadge">@rec.QualityScore</span></td>
                                    <td>@rec.CompletedOrders</td>
                                    <td>@rec.AverageRating.ToString("F1")</td>
                                    <td>
                                        @{
                                            var availBadge = rec.Availability switch
                                            {
                                                ScholarRescue.Models.Enums.WriterAvailabilityStatus.Available => "bg-success",
                                                ScholarRescue.Models.Enums.WriterAvailabilityStatus.Busy => "bg-warning text-dark",
                                                ScholarRescue.Models.Enums.WriterAvailabilityStatus.Full => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @availBadge">@rec.Availability</span>
                                    </td>
                                    <td>
                                        @if (!isApplied && order?.AssignedWriter == null)
                                        {
                                            <form asp-action="AssignWriterToOrder" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="orderId" value="@(order?.Id ?? 0)" />
                                                <input type="hidden" name="writerId" value="@rec.WriterId" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary"
                                                        onclick="return confirm('Assign @rec.WriterName to this order?');"
                                                        title="Assign directly">
                                                    <i class="bi bi-person-plus"></i> Assign
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Scoring formula: Subject Match (50pts) + Available Capacity (30%) + Quality Score (10%) + Completed Orders (5%) + Avg Rating (5pts).
                    Green rows indicate recommended writers who match the subject and have capacity.
                </div>
            </div>
        </div>
    }

    @* Applicants List *@
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Applicants (@Model.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-4 text-muted"></i>
                    <h6 class="mt-3 text-muted">No applicants yet</h6>
                    <p class="text-muted">This order has not received any writer applications.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Writer</th>
                                <th>Email</th>
                                <th>Applied</th>
                                <th>Status</th>
                                <th>Message</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@app.Writer?.FirstName @app.Writer?.LastName</strong>
                                    </td>
                                    <td>@app.Writer?.Email</td>
                                    <td>
                                        <small class="text-muted">@app.AppliedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        @{
                                            var appBadge = app.Status switch
                                            {
                                                OrderApplicationStatus.Pending => "bg-warning text-dark",
                                                OrderApplicationStatus.Selected => "bg-success",
                                                OrderApplicationStatus.Declined => "bg-danger",
                                                OrderApplicationStatus.Withdrawn => "bg-secondary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @appBadge">@app.Status</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(app.Message))
                                        {
                                            <span class="text-truncate d-inline-block" style="max-width: 200px;"
                                                  title="@app.Message">@app.Message</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (app.Status == OrderApplicationStatus.Pending && order?.AssignedWriter == null)
                                        {
                                            <div class="btn-group btn-group-sm">
                                                <form asp-action="AssignWriterToOrder" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="orderId" value="@app.OrderId" />
                                                    <input type="hidden" name="writerId" value="@app.WriterId" />
                                                    <button type="submit" class="btn btn-success"
                                                            onclick="return confirm('Assign this writer to the order?');"
                                                            title="Assign">
                                                        <i class="bi bi-check-circle"></i> Assign
                                                    </button>
                                                </form>
                                                <form asp-action="RejectOrderApplication" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                                    <button type="submit" class="btn btn-outline-danger"
                                                            onclick="return confirm('Reject this application?');"
                                                            title="Reject">
                                                        <i class="bi bi-x-circle"></i> Reject
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">No actions available</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>