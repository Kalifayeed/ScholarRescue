@model ScholarRescue.Models.QaReview
@using ScholarRescue.Models
@using ScholarRescue.Models.Enums
@{ var order = ViewBag.Order as Order; ViewData["Title"] = $"QA Review - {order?.OrderNumber}"; }

<div class="mb-4">
    <nav aria-label="breadcrumb"><ol class="breadcrumb small">
        <li class="breadcrumb-item"><a asp-action="PendingQa" class="text-decoration-none">Pending QA</a></li>
        <li class="breadcrumb-item active">@order?.OrderNumber</li>
    </ol></nav>
    <h4 class="mb-1"><i class="bi bi-check2-square me-2"></i>QA Review: @order?.OrderNumber</h4>
    <p class="text-muted small mb-0">@order?.Title &middot; @(order?.AssignedWriter?.FirstName ?? "") @(order?.AssignedWriter?.LastName ?? "")</p>
</div>

<div class="row g-3">
    <div class="col-lg-7">
        <form asp-action="QaReview" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="OrderId" value="@Model.OrderId" />

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-list-check me-1"></i>Checklist</h6></div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="formattingPassed" name="FormattingPassed" value="true" />
                        <label class="form-check-label" for="formattingPassed">Formatting meets standards (font, margins, spacing, headings)</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="wordCountPassed" name="WordCountPassed" value="true" />
                        <label class="form-check-label" for="wordCountPassed">Word count matches requirements</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="filesPassed" name="FilesPassed" value="true" />
                        <label class="form-check-label" for="filesPassed">All required files are present and properly uploaded</label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="instructionsPassed" name="InstructionsPassed" value="true" />
                        <label class="form-check-label" for="instructionsPassed">All client instructions were followed</label>
                    </div>
                    <input type="hidden" name="FormattingPassed" value="false" />
                    <input type="hidden" name="WordCountPassed" value="false" />
                    <input type="hidden" name="FilesPassed" value="false" />
                    <input type="hidden" name="InstructionsPassed" value="false" />
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-file-earmark-text me-1"></i>Documents</h6></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Plagiarism Report</label>
                        <input type="file" name="plagiarismReport" class="form-control" accept=".pdf,.jpg,.png" />
                        <span class="text-muted small">Upload a PDF or screenshot of the plagiarism check result.</span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Notes (optional)</label>
                        <textarea name="Notes" class="form-control" rows="3" placeholder="Any additional notes about this review..."></textarea>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" name="IsApproved" value="true" class="btn btn-success">
                    <i class="bi bi-check-circle me-1"></i>Approve & Deliver to Client
                </button>
                <button type="submit" name="IsApproved" value="false" class="btn btn-outline-warning">
                    <i class="bi bi-x-circle me-1"></i>Mark as Needs Revision
                </button>
                <a asp-action="PendingQa" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-1"></i>Order Info</h6></div>
            <div class="card-body small">
                <div><strong>Order:</strong> @order?.OrderNumber</div>
                <div><strong>Client:</strong> @(order?.Client?.FirstName ?? "") @(order?.Client?.LastName ?? "")</div>
                <div><strong>Writer:</strong> @(order?.AssignedWriter?.FirstName ?? "") @(order?.AssignedWriter?.LastName ?? "")</div>
                <div><strong>Pages:</strong> @order?.Pages</div>
                <div><strong>Budget:</strong> $@order?.Budget.ToString("F2")</div>
                <div><strong>Deadline:</strong> @order?.Deadline.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light"><h6 class="mb-0 fw-semibold"><i class="bi bi-cloud-download me-1"></i>Submitted Files</h6></div>
            <div class="card-body small">
                @{ var submissions = ViewBag.Submissions as List<OrderSubmission> ?? new(); }
                @if (!submissions.Any()) { <p class="text-muted mb-0">No submissions found.</p> }
                else {
                    <ul class="list-unstyled mb-0">
                        @foreach (var s in submissions.OrderByDescending(s => s.VersionNumber))
                        {
                            <li class="mb-1"><a href="@s.FilePath" target="_blank"><i class="bi bi-paperclip me-1"></i>v@s.VersionNumber: @s.FileName</a> <span class="text-muted">(@s.SubmissionType)</span></li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>