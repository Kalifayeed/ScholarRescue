@model IEnumerable<ScholarRescue.Models.Order>
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = "Order Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var statusFilter = Context.Request.Query["statusFilter"].FirstOrDefault();
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-cart-check"></i> Order Management</h2>
            <small class="text-muted">View, assign, and manage all orders on the platform.</small>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Filter Bar *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="OrderManagement" class="btn btn-sm @(string.IsNullOrEmpty(statusFilter) ? "btn-primary" : "btn-outline-primary")">All</a>
                @foreach (OrderStatus s in Enum.GetValues<OrderStatus>())
                {
                    <a asp-action="OrderManagement" asp-route-statusFilter="@s.ToString()"
                       class="btn btn-sm @(statusFilter == s.ToString() ? "btn-primary" : "btn-outline-primary")">
                        @s
                    </a>
                }
            </div>
        </div>
    </div>

    @* Orders Table *@
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Order #</th>
                            <th>Title</th>
                            <th>Client</th>
                            <th>Status</th>
                            <th>Budget</th>
                            <th>Writer</th>
                            <th>Applicants</th>
                            <th>Deadline</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4">
                                    <i class="bi bi-inbox display-6 text-muted"></i>
                                    <p class="text-muted mt-2 mb-0">No orders found.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td><strong>@order.OrderNumber</strong></td>
                                <td>@(order.Title.Length > 40 ? order.Title[..40] + "..." : order.Title)</td>
                                <td>@order.Client.FirstName @order.Client.LastName</td>
                                <td>
                                    @{
                                        var badgeClass = order.Status switch
                                        {
                                            OrderStatus.Draft => "bg-secondary",
                                            OrderStatus.PendingReview => "bg-info",
                                            OrderStatus.Open => "bg-success",
                                            OrderStatus.Assigned => "bg-primary",
                                            OrderStatus.InProgress => "bg-warning text-dark",
                                            OrderStatus.DraftSubmitted => "bg-info",
                                            OrderStatus.RevisionRequested => "bg-danger",
                                            OrderStatus.Completed => "bg-success",
                                            OrderStatus.Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@order.Status</span>
                                </td>
                                <td>@order.Budget.ToString("C")</td>
                                <td>
                                    @if (order.AssignedWriter != null)
                                    {
                                        <span>@order.AssignedWriter.FirstName @order.AssignedWriter.LastName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td>
                                    @if (order.Applications != null && order.Applications.Any())
                                    {
                                        <a asp-action="OrderApplicants" asp-route-id="@order.Id"
                                           class="badge bg-info text-dark text-decoration-none">
                                            @order.Applications.Count applicant(s)
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                </td>
                                <td>
                                    <span class="@(order.Deadline < DateTime.UtcNow ? "text-danger" : "")">
                                        @order.Deadline.ToString("MMM dd, yyyy")
                                    </span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        @if (order.Status == OrderStatus.Open || order.Status == OrderStatus.Assigned)
                                        {
                                            <a asp-action="OrderApplicants" asp-route-id="@order.Id"
                                               class="btn btn-outline-primary" title="Manage Applicants">
                                                <i class="bi bi-people"></i>
                                            </a>
                                        }
                                        @if (order.Status == OrderStatus.Assigned)
                                        {
                                            <form asp-action="ReassignOrder" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="orderId" value="@order.Id" />
                                                <button type="submit" class="btn btn-outline-warning"
                                                        onclick="return confirm('Return this order to the marketplace?');"
                                                        title="Reassign to Marketplace">
                                                    <i class="bi bi-arrow-return-left"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (order.AssignedWriterId != null)
                                        {
                                            <a asp-controller="Orders" asp-action="Workspace" asp-route-id="@order.Id"
                                               class="btn btn-outline-success" title="Open Workspace">
                                                <i class="bi bi-layout-sidebar"></i>
                                            </a>
                                        }
                                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                           class="btn btn-outline-info" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>