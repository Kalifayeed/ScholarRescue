@model ScholarRescue.ViewModels.Order.OrderTimelineViewModel

@{
    ViewData["Title"] = "Order Timeline - " + Model.OrderNumber;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container-fluid px-4 py-3">
    <!-- Activity Summary Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Order Activity</h5>
            <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left me-1"></i> Back to Order
            </a>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <small class="text-muted d-block">Order #</small>
                    <strong>@Model.OrderNumber</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Status</small>
                    <span class="badge bg-@(Model.StatusColor)">@Model.Status</span>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Deadline</small>
                    <strong class="@(Model.IsOverdue ? "text-danger" : "")">@Model.DeadlineDisplay</strong>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Time Remaining</small>
                    <strong class="@(Model.IsOverdue ? "text-danger" : "")">@Model.TimeRemaining</strong>
                </div>
            </div>

            <!-- Progress Bar -->
            <div class="mt-3">
                <div class="d-flex justify-content-between mb-1">
                    <small class="text-muted">Progress</small>
                    <small class="fw-bold">@Model.Progress%</small>
                </div>
                <div class="progress" style="height:8px;">
                    <div class="progress-bar bg-@(Model.Progress >= 100 ? "success" : "primary")"
                         role="progressbar" style="width:@Model.Progress%;"
                         aria-valuenow="@Model.Progress" aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="d-flex flex-wrap gap-2 mb-3">
        <a href="?filter=all" class="btn btn-sm @(Model.Filter == "all" ? "btn-primary" : "btn-outline-primary")">All Events</a>
        <a href="?filter=client" class="btn btn-sm @(Model.Filter == "client" ? "btn-primary" : "btn-outline-primary")">Client</a>
        <a href="?filter=writer" class="btn btn-sm @(Model.Filter == "writer" ? "btn-primary" : "btn-outline-primary")">Writer</a>
        <a href="?filter=admin" class="btn btn-sm @(Model.Filter == "admin" ? "btn-primary" : "btn-outline-primary")">Admin</a>
        <a href="?filter=financial" class="btn btn-sm @(Model.Filter == "financial" ? "btn-primary" : "btn-outline-primary")">Financial</a>
        <a href="?filter=files" class="btn btn-sm @(Model.Filter == "files" ? "btn-primary" : "btn-outline-primary")">Files</a>
    </div>

    <!-- Timeline -->
    @if (!Model.Events.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-4 text-muted"></i>
            <h6 class="mt-2 text-muted">No timeline events yet</h6>
        </div>
    }
    else
    {
        <div class="timeline">
            @foreach (var evt in Model.Events)
            {
                var color = evt.EventType switch
                {
                    ScholarRescue.Models.Enums.TimelineEventType.OrderCreated or
                    ScholarRescue.Models.Enums.TimelineEventType.PaymentReceived or
                    ScholarRescue.Models.Enums.TimelineEventType.WriterApplied or
                    ScholarRescue.Models.Enums.TimelineEventType.MessageSent or
                    ScholarRescue.Models.Enums.TimelineEventType.FileUploaded
                        => "primary",
                    ScholarRescue.Models.Enums.TimelineEventType.WriterAssigned or
                    ScholarRescue.Models.Enums.TimelineEventType.WriterStartedWork or
                    ScholarRescue.Models.Enums.TimelineEventType.DraftSubmitted or
                    ScholarRescue.Models.Enums.TimelineEventType.RevisionSubmitted or
                    ScholarRescue.Models.Enums.TimelineEventType.OrderCompleted or
                    ScholarRescue.Models.Enums.TimelineEventType.ClientApproved
                        => "success",
                    ScholarRescue.Models.Enums.TimelineEventType.RevisionRequested or
                    ScholarRescue.Models.Enums.TimelineEventType.DeadlineWarning or
                    ScholarRescue.Models.Enums.TimelineEventType.DeadlineApproaching
                        => "warning",
                    ScholarRescue.Models.Enums.TimelineEventType.AdminAction => "warning",
                    ScholarRescue.Models.Enums.TimelineEventType.RefundRequested or
                    ScholarRescue.Models.Enums.TimelineEventType.OrderOverdue
                        => "danger",
                    _ => "secondary"
                };

                <div class="timeline-item mb-3">
                    <div class="d-flex">
                        <div class="timeline-marker me-3 text-center" style="width:32px;">
                            <div class="rounded-circle bg-@color bg-opacity-10 d-inline-flex align-items-center justify-content-center"
                                 style="width:32px;height:32px;border:2px solid var(--bs-@color);">
                                <i class="bi @(GetEventIcon(evt.EventType)) text-@color small"></i>
                            </div>
                        </div>
                        <div class="timeline-content flex-grow-1 pb-3 border-start ps-3" style="border-color:#e9ecef !important;">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-1">
                                <div>
                                    <strong class="small">@evt.Title</strong>
                                    @if (!string.IsNullOrEmpty(evt.Description))
                                    {
                                        <p class="mb-0 text-muted small">@evt.Description</p>
                                    }
                                </div>
                                <small class="text-muted flex-shrink-0">@evt.Timestamp.ToLocalTime().ToString("MMM dd yyyy - HH:mm")</small>
                            </div>
                            <small class="text-muted">
                                <i class="bi bi-person me-1"></i>@evt.CreatedByName
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    static string GetEventIcon(ScholarRescue.Models.Enums.TimelineEventType type) => type switch
    {
        ScholarRescue.Models.Enums.TimelineEventType.OrderCreated => "bi-plus-circle",
        ScholarRescue.Models.Enums.TimelineEventType.PaymentReceived => "bi-credit-card",
        ScholarRescue.Models.Enums.TimelineEventType.OrderPublished => "bi-globe",
        ScholarRescue.Models.Enums.TimelineEventType.WriterApplied => "bi-person-plus",
        ScholarRescue.Models.Enums.TimelineEventType.WriterAssigned => "bi-person-check",
        ScholarRescue.Models.Enums.TimelineEventType.WriterReassigned => "bi-arrow-repeat",
        ScholarRescue.Models.Enums.TimelineEventType.WriterStartedWork => "bi-play-circle",
        ScholarRescue.Models.Enums.TimelineEventType.MessageSent => "bi-chat-dots",
        ScholarRescue.Models.Enums.TimelineEventType.FileUploaded => "bi-upload",
        ScholarRescue.Models.Enums.TimelineEventType.DraftSubmitted => "bi-file-text",
        ScholarRescue.Models.Enums.TimelineEventType.RevisionRequested => "bi-arrow-counterclockwise",
        ScholarRescue.Models.Enums.TimelineEventType.RevisionSubmitted => "bi-arrow-clockwise",
        ScholarRescue.Models.Enums.TimelineEventType.OrderCompleted => "bi-check-circle",
        ScholarRescue.Models.Enums.TimelineEventType.ClientApproved => "bi-hand-thumbs-up",
        ScholarRescue.Models.Enums.TimelineEventType.RefundRequested => "bi-cash-stack",
        ScholarRescue.Models.Enums.TimelineEventType.AdminAction => "bi-shield-check",
        ScholarRescue.Models.Enums.TimelineEventType.DeadlineWarning => "bi-alarm",
        ScholarRescue.Models.Enums.TimelineEventType.OrderOverdue => "bi-exclamation-triangle",
        _ => "bi-circle"
    };
}