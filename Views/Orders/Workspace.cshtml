@model ScholarRescue.ViewModels.Order.OrderWorkspaceViewModel
@using ScholarRescue.Models.Enums
@{
    ViewData["Title"] = $"Workspace - {Model.OrderNumber}";
    var isClient = Model.MyRole == "Client";
    var isWriter = Model.MyRole == "Writer";
    var isAdmin = Model.MyRole == "Administrator";
    var assignedStatuses = new[] { OrderStatus.Assigned, OrderStatus.InProgress, OrderStatus.DraftSubmitted, OrderStatus.RevisionRequested, OrderStatus.RevisionSubmitted, OrderStatus.FinalSubmitted, OrderStatus.Completed };
    var showWorkspace = assignedStatuses.Contains(Model.Status) || isAdmin;
}

<div class="container-fluid px-4">
    @* Breadcrumb *@
    <nav aria-label="breadcrumb" class="mt-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Orders" asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item"><a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.Id">@Model.OrderNumber</a></li>
            <li class="breadcrumb-item active">Workspace</li>
        </ol>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="h3 mb-1"><i class="bi bi-layout-sidebar"></i> Order Workspace</h1>
            <span class="text-muted">@Model.OrderNumber &mdash; @Model.Title</span>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Order Details
            </a>
        </div>
    </div>

    @* Main layout: two columns *@
    <div class="row g-4">
        @* Left column: Order info + files + submissions *@
        <div class="col-12 col-lg-4">
            @* Order Summary Card *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white d-flex align-items-center">
                    <i class="bi bi-file-text me-2"></i>
                    <h5 class="mb-0 flex-grow-1">Order Summary</h5>
                    @{
                        var statusBadgeClass = Model.Status switch
                        {
                            OrderStatus.Draft => "bg-secondary",
                            OrderStatus.PendingReview => "bg-info text-dark",
                            OrderStatus.Open => "bg-success",
                            OrderStatus.Assigned => "bg-primary",
                            OrderStatus.InProgress => "bg-warning text-dark",
                            OrderStatus.DraftSubmitted => "bg-info",
                            OrderStatus.RevisionRequested => "bg-warning text-dark",
                            OrderStatus.RevisionSubmitted => "bg-info",
                            OrderStatus.FinalSubmitted => "bg-success",
                            OrderStatus.Completed => "bg-success",
                            OrderStatus.Cancelled => "bg-danger",
                            _ => "bg-secondary"
                        };
                    }
                    <span class="badge @statusBadgeClass">@Model.Status</span>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">Title</small>
                        <span class="fw-semibold">@Model.Title</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Subject</small>
                        <span>@Model.Subject</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Academic Level</small>
                        <span>@Model.AcademicLevelName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Citation Format</small>
                        <span>@Model.CitationFormatName</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Pages / Word Count</small>
                        <span>@Model.Pages pages / @Model.WordCount words</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Deadline</small>
                        <span class="fw-bold @(Model.Deadline < DateTime.UtcNow ? "text-danger" : "")">
                            @Model.Deadline.ToString("MMMM dd, yyyy h:mm tt")
                        </span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Budget</small>
                        <span class="fw-bold text-success">@Model.Budget.ToString("C")</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <div class="mb-0">
                            <small class="text-muted d-block">Instructions</small>
                            <p class="mb-0 text-break small">@Model.Description</p>
                        </div>
                    }
                </div>
            </div>

            @* Assignment / People Card *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-people me-2"></i>
                    <h5 class="mb-0 d-inline">Assignment</h5>
                </div>
                <div class="card-body">
                    @if (Model.IsAssigned)
                    {
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="fw-semibold">Assigned</span>
                        </div>
                        <div class="ps-4">
                            <small class="text-muted d-block">@Model.OtherPartyLabel</small>
                            <span class="fw-semibold">@Model.OtherPartyName</span>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-hourglass-split text-warning me-2"></i>
                            <span class="fw-semibold">Awaiting assignment</span>
                        </div>
                        <div class="ps-4">
                            <small class="text-muted">A writer has not yet been assigned to this order.</small>
                        </div>
                    }
                    <hr />
                    <div class="ps-2">
                        <small class="text-muted d-block">Your Role</small>
                        <span class="badge bg-dark">@Model.MyRole</span>
                    </div>
                </div>
            </div>

            @* Progress Timeline *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-list-check me-2"></i>
                    <h5 class="mb-0 d-inline">Progress Timeline</h5>
                </div>
                <div class="card-body">
                    @{
                        var steps = new[] {
                            new { Label = "Created", Icon = "bi-plus-circle", Complete = true },
                            new { Label = "Posted to Marketplace", Icon = "bi-shop", Complete = Model.Status >= OrderStatus.Open },
                            new { Label = "Writer Assigned", Icon = "bi-person-check", Complete = Model.Status >= OrderStatus.Assigned },
                            new { Label = "In Progress", Icon = "bi-arrow-repeat", Complete = Model.Status >= OrderStatus.InProgress },
                            new { Label = "Draft Submitted", Icon = "bi-file-earmark-check", Complete = Model.Status >= OrderStatus.DraftSubmitted },
                            new { Label = "Completed", Icon = "bi-check-circle", Complete = Model.Status == OrderStatus.Completed }
                        };
                    }
                    <ul class="list-unstyled mb-0">
                        @foreach (var step in steps)
                        {
                            <li class="d-flex align-items-center mb-2 @(!step.Complete ? "text-muted" : "")">
                                <i class="bi @step.Icon me-2 @(step.Complete ? "text-success" : "")"></i>
                                <span>@step.Label</span>
                                @if (step.Complete)
                                {
                                    <i class="bi bi-check2 ms-auto text-success"></i>
                                }
                            </li>
                        }
                    </ul>
                </div>
            </div>

            @* Files / Attachments *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-paperclip me-2"></i>
                    <h5 class="mb-0 d-inline">Attachments</h5>
                </div>
                <div class="card-body">
                    @if (Model.HasAttachments)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var file in Model.Attachments)
                            {
                                <div class="list-group-item d-flex align-items-center px-0 border-0">
                                    <i class="bi bi-file-earmark me-2 text-primary"></i>
                                    <div class="flex-grow-1 min-w-0">
                                        <span class="d-block text-truncate small">@file.FileName</span>
                                        <small class="text-muted">
                                            @(file.FileSize >= 1048576 ? $"{file.FileSize / 1048576.0:F1} MB" :
                                              file.FileSize >= 1024 ? $"{file.FileSize / 1024.0:F1} KB" :
                                              $"{file.FileSize} B")
                                        </small>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="bi bi-folder2-open d-block mb-1" style="font-size:1.5rem;"></i>
                            <small>Files and drafts will appear here.</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Right column: Submissions + Messaging *@
        <div class="col-12 col-lg-8">
            @* Submissions / Drafts Section *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-file-earmark-check me-2"></i>
                        <h5 class="mb-0 d-inline">Submissions & Drafts</h5>
                    </div>
                    @if (Model.HasSubmissions)
                    {
                        <span class="badge bg-light text-dark">@Model.Submissions.Count submission(s)</span>
                    }
                </div>
                <div class="card-body">
                    @if (Model.HasSubmissions)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Version</th>
                                        <th>Type</th>
                                        <th>File</th>
                                        <th>Uploaded By</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in Model.Submissions)
                                    {
                                        <tr>
                                            <td>v@(sub.VersionNumber)</td>
                                            <td>
                                                <span class="badge @(sub.SubmissionType == SubmissionType.Draft ? "bg-secondary" : sub.SubmissionType == SubmissionType.Revision ? "bg-warning text-dark" : "bg-success")">
                                                    @sub.SubmissionType
                                                </span>
                                            </td>
                                            <td class="text-truncate" style="max-width:150px;" title="@sub.FileName">@sub.FileName</td>
                                            <td>
                                                @if (isAdmin)
                                                {
                                                    <span>@(sub.Writer?.FirstName ?? "Writer") @(sub.Writer?.LastName ?? "")</span>
                                                }
                                                else
                                                {
                                                    <span>Writer</span>
                                                }
                                            </td>
                                            <td><small>@sub.SubmittedAt.ToString("MMM dd, h:mm tt")</small></td>
                                             <td>
                                                 @{
                                                     var isPaid = Model.PaymentStatus == OrderPaymentStatus.Paid;
                                                     var ext = System.IO.Path.GetExtension(sub.FileName)?.ToLowerInvariant();
                                                     var isTxt = ext == ".txt";
                                                 }
                                                 @if (isAdmin || isWriter || isPaid)
                                                 {
                                                     <a asp-action="DownloadSubmission" asp-route-submissionId="@sub.Id"
                                                        class="btn btn-sm btn-outline-primary" title="Download">
                                                         <i class="bi bi-download"></i>
                                                     </a>
                                                 }
                                                 else if (isTxt)
                                                 {
                                                     <a asp-action="DownloadSubmission" asp-route-submissionId="@sub.Id"
                                                        class="btn btn-sm btn-outline-warning" title="Download Preview (25%)" aria-label="Download Preview (25%)">
                                                         <i class="bi bi-file-earmark-text"></i> Preview (25%)
                                                     </a>
                                                 }
                                                 else
                                                 {
                                                     <span class="d-inline-block" tabindex="0" data-bs-toggle="tooltip" title="Full download available after payment">
                                                         <button class="btn btn-sm btn-outline-secondary" disabled aria-disabled="true">
                                                             <i class="bi bi-lock-fill"></i>
                                                         </button>
                                                     </span>
                                                     @if (Model.PaymentDeferred)
                                                     {
                                                         <a asp-controller="Payments" asp-action="Checkout" asp-route-orderId="@Model.Id" class="btn btn-sm btn-outline-success ms-1">
                                                             <i class="bi bi-credit-card"></i> Pay Now
                                                         </a>
                                                     }
                                                 }
                                             </td>
                                        </tr>
                                        @if (!string.IsNullOrWhiteSpace(sub.Comments))
                                        {
                                            <tr class="table-light">
                                                <td colspan="6" class="py-1 ps-5">
                                                    <small class="text-muted"><i class="bi bi-chat-quote me-1"></i>@sub.Comments</small>
                                                </td>
                                            </tr>
                                        }
                                        @if (sub.ReviewedAttachment != null)
                                        {
                                            <tr class="table-light">
                                                <td colspan="6" class="py-1 ps-5 text-muted">
                                                    <small><i class="bi bi-paperclip me-1"></i>Feedback on: @sub.ReviewedAttachment.FileName</small>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-file-earmark-plus d-block mb-2" style="font-size:2rem;"></i>
                            <h6>No drafts submitted yet.</h6>
                            <p class="small mb-0">The writer will upload drafts here for your review.</p>
                        </div>
                    }

                    @* Writer: Upload Draft Form *@
                    @if (Model.CanSubmitWork)
                    {
                        var requiresDraftRef = Model.RequestType == RequestType.DraftFeedback || Model.RequestType == RequestType.ProofreadingOwnWork;
                        var draftAttachments = Model.Attachments.Where(a => a.AttachmentPurpose == AttachmentPurpose.StudentDraft).ToList();

                        <hr />
                        <h6 class="fw-semibold"><i class="bi bi-upload me-1"></i> Submit Work</h6>
                        <form asp-action="SubmitWork" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="mt-2">
                            @Html.AntiForgeryToken()
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label small">File (PDF, DOC, DOCX, ZIP - max 25MB)</label>
                                    <input type="file" name="file" class="form-control form-control-sm" required accept=".pdf,.doc,.docx,.zip" />
                                </div>

                                @if (requiresDraftRef && draftAttachments.Count > 0)
                                {
                                    <div class="col-12">
                                        <label for="reviewedAttachmentId" class="form-label small">Which draft are you providing feedback on? <span class="text-danger">*</span></label>
                                        <select name="reviewedAttachmentId" id="reviewedAttachmentId" class="form-select form-select-sm" required>
                                            <option value="">-- Select a draft --</option>
                                            @foreach (var att in draftAttachments)
                                            {
                                                <option value="@att.Id">@att.FileName</option>
                                            }
                                        </select>
                                    </div>
                                }

                                <div class="col-12">
                                    @if (requiresDraftRef)
                                    {
                                        <label for="comments" class="form-label small">Feedback Notes <span class="text-danger">*</span></label>
                                        <textarea name="comments" id="comments" class="form-control form-control-sm" rows="3" maxlength="2000" minlength="20" required placeholder="Provide detailed feedback (minimum 20 characters)..."></textarea>
                                        <div class="form-text">Detailed feedback notes are required (minimum 20 characters).</div>
                                    }
                                    else
                                    {
                                        <label for="comments" class="form-label small">Notes / Comments (optional)</label>
                                        <textarea name="comments" id="comments" class="form-control form-control-sm" rows="2" maxlength="2000" placeholder="Add a note about this submission..."></textarea>
                                    }
                                </div>

                                @if (requiresDraftRef && draftAttachments.Count == 0)
                                {
                                    <div class="col-12">
                                        <div class="alert alert-warning py-2 small mb-0">
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            This order requires feedback on a client draft, but no Student Draft attachments are available.
                                            Contact support if you believe this is an error.
                                        </div>
                                    </div>
                                }

                                <div class="col-12">
                                    <div class="d-flex gap-2">
                                        <button type="submit" name="submissionType" value="Draft" class="btn btn-primary btn-sm">
                                            <i class="bi bi-send"></i> Submit Draft
                                        </button>
                                        @if (Model.Status == OrderStatus.RevisionRequested)
                                        {
                                            <button type="submit" name="submissionType" value="Revision" class="btn btn-warning btn-sm">
                                                <i class="bi bi-arrow-repeat"></i> Submit Revision
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </form>
                    }

                    @* Client: Request Revision Form *@
                    @if (Model.CanRequestRevision)
                    {
                        <hr />
                        <h6 class="fw-semibold text-warning"><i class="bi bi-arrow-repeat me-1"></i> Request Revision</h6>
                        <form asp-action="RequestRevision" asp-route-id="@Model.Id" method="post" class="mt-2">
                            @Html.AntiForgeryToken()
                            <div class="row g-2">
                                <div class="col-12">
                                    <label class="form-label small">Revision Instructions <span class="text-danger">*</span></label>
                                    <textarea name="comments" class="form-control form-control-sm" rows="3" maxlength="2000" required
                                              placeholder="Describe what changes are needed (min 10 characters)..."></textarea>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-warning btn-sm">
                                        <i class="bi bi-arrow-repeat"></i> Request Revision
                                    </button>
                                </div>
                            </div>
                        </form>
                    }

                    @* Client: Accept Work Button *@
                    @if (Model.CanAcceptWork)
                    {
                        <hr />
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="fw-semibold text-success mb-1"><i class="bi bi-check-circle me-1"></i> Accept Work</h6>
                                <small class="text-muted">Mark this order as completed. No payment will be released at this stage.</small>
                            </div>
                            <form asp-action="AcceptWork" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success"
                                        onclick="return confirm('Mark this order as completed? No payment will be released yet.');">
                                    <i class="bi bi-check-lg"></i> Accept & Complete
                                </button>
                            </form>
                        </div>
                    }

                    @* Revision History *@
                    @if (Model.HasRevisions)
                    {
                        <hr />
                        <h6 class="fw-semibold"><i class="bi bi-clock-history me-1"></i> Revision History</h6>
                        <div class="list-group list-group-flush mt-2">
                            @foreach (var rev in Model.RevisionRequests)
                            {
                                <div class="list-group-item px-0 border-0">
                                    <div class="d-flex justify-content-between">
                                        <small class="text-muted">
                                            <i class="bi bi-person me-1"></i>
                                            @if (isAdmin)
                                            {
                                                <span>@(rev.Client?.FirstName ?? "Client") @(rev.Client?.LastName ?? "")</span>
                                            }
                                            else
                                            {
                                                <span>Client</span>
                                            }
                                        </small>
                                        <small class="text-muted">@rev.RequestedAt.ToString("MMM dd, h:mm tt")</small>
                                    </div>
                                    <p class="mb-0 small mt-1">@rev.Comments</p>
                                    <span class="badge @(rev.Status == RevisionRequestStatus.Pending ? "bg-warning text-dark" : "bg-success") mt-1">
                                        @rev.Status
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Messaging Section *@
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <div>
                        <i class="bi bi-chat-dots me-2"></i>
                        <h5 class="mb-0 d-inline">Conversation</h5>
                    </div>
                    @if (Model.ConversationId.HasValue)
                    {
                        <a asp-controller="Messages" asp-action="Conversation" asp-route-id="@Model.ConversationId.Value"
                           class="btn btn-light btn-sm">
                            <i class="bi bi-box-arrow-up-right"></i> Open Full Chat
                        </a>
                    }
                </div>
                <div class="card-body d-flex flex-column" style="min-height: 300px;">
                    @if (Model.IsAssigned && (isClient || isWriter || isAdmin))
                    {
                        @if (Model.ConversationId.HasValue)
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-chat-square-text display-4 d-block mb-3 text-primary"></i>
                                <h5>Chat with @Model.OtherPartyLabel</h5>
                                <p class="text-muted mb-3">
                                    Communicate with the @Model.OtherPartyLabel.ToLower() about this order.
                                    All messages are private between authorized participants.
                                </p>
                                <a asp-controller="Messages" asp-action="Conversation" asp-route-id="@Model.ConversationId.Value"
                                   class="btn btn-primary px-5">
                                    <i class="bi bi-chat-dots"></i> Open Conversation
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-chat-square-text display-4 d-block mb-3 text-muted"></i>
                                <h5>No Conversation Yet</h5>
                                <p class="text-muted mb-3">
                                    Start a conversation to discuss the order.
                                </p>
                                <a asp-controller="Messages" asp-action="ForOrder" asp-route-orderId="@Model.Id"
                                   class="btn btn-primary px-5">
                                    <i class="bi bi-chat-dots"></i> Start Conversation
                                </a>
                            </div>
                        }
                    }
                    else if (!Model.IsAssigned)
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-lock display-4 d-block mb-3"></i>
                            <h5>Messaging Unavailable</h5>
                            <p class="mb-0">Messaging is only available after a writer has been assigned to this order.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}