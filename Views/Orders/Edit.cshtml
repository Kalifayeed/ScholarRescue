@model ScholarRescue.ViewModels.Order.EditOrderViewModel

@{
    ViewData["Title"] = "Edit Order";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit @Model.OrderNumber</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="card-title mb-0"><i class="bi bi-pencil"></i> Edit Order @Model.OrderNumber</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Order Number</label>
                                <input asp-for="OrderNumber" class="form-control" readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-bold"></label>
                                <select asp-for="Status" class="form-select"
                                        asp-items="Html.GetEnumSelectList<ScholarRescue.Models.Enums.OrderStatus>()">
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-bold"></label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Description" class="form-label fw-bold"></label>
                                <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Subject" class="form-label fw-bold"></label>
                                <input asp-for="Subject" class="form-control" />
                                <span asp-validation-for="Subject" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="AcademicLevel" class="form-label fw-bold"></label>
                                <select asp-for="AcademicLevel" class="form-select" id="academicLevel"
                                        asp-items="Html.GetEnumSelectList<ScholarRescue.Models.Enums.AcademicLevel>()">
                                </select>
                                <span asp-validation-for="AcademicLevel" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CitationFormat" class="form-label fw-bold"></label>
                                <select asp-for="CitationFormat" class="form-select"
                                        asp-items="Html.GetEnumSelectList<ScholarRescue.Models.Enums.CitationFormat>()">
                                </select>
                                <span asp-validation-for="CitationFormat" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Deadline" class="form-label fw-bold"></label>
                                <input asp-for="Deadline" class="form-control" id="deadline" type="datetime-local" />
                                <span asp-validation-for="Deadline" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Pages" class="form-label fw-bold"></label>
                                <input asp-for="Pages" class="form-control" id="pages" type="number" min="1" />
                                <span asp-validation-for="Pages" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="NumberOfSources" class="form-label fw-bold"></label>
                                <input asp-for="NumberOfSources" class="form-control" type="number" min="0" />
                                <span asp-validation-for="NumberOfSources" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Auto-calculated pricing display (read-only) -->
                        <div class="card bg-light mt-3 mb-3">
                            <div class="card-body">
                                <h6 class="card-title fw-bold"><i class="bi bi-calculator"></i> Automatic Price Calculation</h6>
                                <div class="row g-2">
                                    <div class="col-sm-4">
                                        <small class="text-muted d-block">Word Count (auto):</small>
                                        <strong id="wordCountDisplay">@Model.WordCount</strong>
                                        <small class="text-muted"> words</small>
                                    </div>
                                    <div class="col-sm-4">
                                        <small class="text-muted d-block">Total Price (auto):</small>
                                        <strong id="totalPriceDisplay" class="text-primary">@Model.Budget.ToString("C")</strong>
                                    </div>
                                    <div class="col-sm-4">
                                        <small class="text-muted d-block">Commission (10%):</small>
                                        <strong>@Model.CommissionAmount.ToString("C")</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <partial name="_ValidationScriptsPartial" />
    <script>
        var baseRates = { HighSchool: 5, College: 6, Undergraduate: 7, Masters: 8, PhD: 9 };
        var wordsPerPage = 300;

        document.addEventListener('DOMContentLoaded', function () {
            var acadEl = document.getElementById('academicLevel');
            var pagesEl = document.getElementById('pages');
            var deadlineEl = document.getElementById('deadline');

            if (acadEl) acadEl.addEventListener('change', updatePricing);
            if (pagesEl) pagesEl.addEventListener('input', updatePricing);
            if (deadlineEl) deadlineEl.addEventListener('change', updatePricing);
        });

        function updatePricing() {
            var level = document.getElementById('academicLevel')?.value || '';
            var pages = parseInt(document.getElementById('pages')?.value || 0) || 0;
            var deadline = document.getElementById('deadline')?.value || '';

            var wordCount = pages * wordsPerPage;
            document.getElementById('wordCountDisplay').textContent = wordCount;

            var baseRate = baseRates[level] || 0;
            var surcharge = 0;
            if (deadline) {
                var hours = (new Date(deadline) - new Date()) / (1000 * 60 * 60);
                if (hours <= 12) surcharge = 2;
                else if (hours <= 24) surcharge = 1;
            }
            var total = pages * (baseRate + surcharge);
            document.getElementById('totalPriceDisplay').textContent = '$' + total.toFixed(2);
        }
    </script>
}