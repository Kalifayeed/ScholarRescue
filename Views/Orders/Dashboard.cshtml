@model ScholarRescue.ViewModels.Order.ClientDashboardViewModel

@{
    ViewData["Title"] = "Client Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6">
            <i class="bi bi-speedometer2"></i> My Dashboard
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Order
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-primary fw-bold">@Model.TotalOrders</div>
                    <h5 class="card-title text-muted mt-2">
                        <i class="bi bi-file-text"></i> Total Orders
                    </h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-info fw-bold">@Model.OpenOrders</div>
                    <h5 class="card-title text-muted mt-2">
                        <i class="bi bi-folder"></i> Open
                    </h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-warning fw-bold">@Model.InProgressOrders</div>
                    <h5 class="card-title text-muted mt-2">
                        <i class="bi bi-arrow-repeat"></i> In Progress
                    </h5>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success shadow-sm h-100">
                <div class="card-body text-center">
                    <div class="display-4 text-success fw-bold">@Model.CompletedOrders</div>
                    <h5 class="card-title text-muted mt-2">
                        <i class="bi bi-check-circle"></i> Completed
                    </h5>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Messages -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="bi bi-chat-dots"></i> Recent Messages</h5>
                    <a asp-controller="Messages" asp-action="Index" class="btn btn-light btn-sm">
                        <i class="bi bi-chat-square-text"></i> All Messages
                    </a>
                </div>
                <div class="card-body" id="recentMessagesWidget">
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Loading messages...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-clock-history"></i> Recent Orders</h5>
            <a asp-action="Index" class="btn btn-light btn-sm">View All Orders</a>
        </div>
        <div class="card-body">
            @if (!Model.RecentOrders.Any())
            {
                <div class="text-center py-4">
                    <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                    <h6 class="mt-3 text-muted">No orders yet</h6>
                    <a asp-action="Create" class="btn btn-primary mt-2">Create Your First Order</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order #</th>
                                <th>Title</th>
                                <th>Writer</th>
                                <th>Status</th>
                                <th>Pages</th>
                                <th>Budget</th>
                                <th>Deadline</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>@order.OrderNumber</strong></td>
                                    <td>
                                        <span title="@order.Title">
                                            @(order.Title.Length > 35 ? order.Title[..35] + "..." : order.Title)
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(order.WriterName))
                                        {
                                            @order.WriterName
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Not assigned</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = order.Status switch
                                            {
                                                ScholarRescue.Models.Enums.OrderStatus.Draft => "bg-secondary",
                                                ScholarRescue.Models.Enums.OrderStatus.PendingReview => "bg-info text-dark",
                                                ScholarRescue.Models.Enums.OrderStatus.Open => "bg-primary",
                                                ScholarRescue.Models.Enums.OrderStatus.Assigned => "bg-primary",
                                                ScholarRescue.Models.Enums.OrderStatus.InProgress => "bg-warning text-dark",
                                        ScholarRescue.Models.Enums.OrderStatus.DraftSubmitted => "bg-info",
                                                ScholarRescue.Models.Enums.OrderStatus.RevisionRequested => "bg-warning text-dark",
                                                ScholarRescue.Models.Enums.OrderStatus.Completed => "bg-success",
                                                ScholarRescue.Models.Enums.OrderStatus.Cancelled => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@order.Status</span>
                                    </td>
                                    <td>@order.Pages</td>
                                    <td>@order.Budget.ToString("C")</td>
                                    <td>
                                        <span title="@order.Deadline.ToString("g")">
                                            @order.Deadline.ToString("MMM dd")
                                        </span>
                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group btn-group-sm" role="group">
                                                            <a asp-action="Details" asp-route-id="@order.Id"
                                                               class="btn btn-outline-info" title="View Details">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                            @if (order.Status == OrderStatus.Assigned ||
                                                                 order.Status == OrderStatus.InProgress ||
                                                                 order.Status == OrderStatus.DraftSubmitted ||
                                                                 order.Status == OrderStatus.RevisionRequested)
                                                            {
                                                                <a asp-action="Workspace" asp-route-id="@order.Id"
                                                                   class="btn btn-outline-success" title="Open Workspace">
                                                                    <i class="bi bi-layout-sidebar"></i>
                                                                </a>
                                                            }
                                                            @if (order.Status != OrderStatus.Completed)
                                                            {
                                                                <a asp-action="Edit" asp-route-id="@order.Id"
                                                                   class="btn btn-outline-primary" title="Edit">
                                                                    <i class="bi bi-pencil"></i>
                                                                </a>
                                                            }
                                                        </div>
                                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            loadRecentMessages();
            setupSignalR();
        });

        function loadRecentMessages() {
            var widget = document.getElementById('recentMessagesWidget');
            if (!widget) return;

            fetch('/Messages/Recent?take=5')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data || !data.success) {
                        widget.innerHTML = '<div class="text-center py-3 text-muted"><p class="small mb-0">Could not load messages.</p></div>';
                        return;
                    }
                    if (!data.conversations || data.conversations.length === 0) {
                        widget.innerHTML = '<div class="text-center py-3 text-muted"><i class="bi bi-inbox d-block mb-1" style="font-size:2rem;"></i><p class="small mb-0">No recent messages.</p></div>';
                        return;
                    }
                    var html = '<div class="list-group list-group-flush">';
                    data.conversations.forEach(function (c) {
                        var time = formatRelativeLocal(c.lastMessageDate);
                        var unreadBadge = c.unreadCount > 0 ? '<span class="badge bg-danger rounded-pill ms-auto">' + c.unreadCount + '</span>' : '';
                        var online = c.isOtherPartyOnline
                            ? '<span class="text-success"><i class="bi bi-circle-fill" style="font-size:0.5rem;"></i></span>'
                            : '<span class="text-muted"><i class="bi bi-circle" style="font-size:0.5rem;"></i></span>';
                        html += '<a href="/Messages/Conversation/' + c.conversationId + '" class="list-group-item list-group-item-action d-flex align-items-start py-2 px-3">' +
                            '<div class="flex-grow-1 min-w-0">' +
                            '<div class="d-flex justify-content-between align-items-center">' +
                            '<strong class="text-truncate small">' + escapeHtml(c.otherPartyName || c.orderNumber) + '</strong>' +
                            '<small class="text-muted ms-2 flex-shrink-0">' + time + '</small>' +
                            '</div>' +
                            '<div class="small text-muted text-truncate">' +
                            '<span class="fw-medium">' + escapeHtml(c.orderNumber) + ':</span> ' +
                            escapeHtml(c.lastMessagePreview || '') +
                            '</div>' +
                            '<div class="d-flex align-items-center gap-1 mt-1">' +
                            online +
                            '<small class="text-muted" style="font-size:0.7rem;">' + escapeHtml(c.otherPartyName || '') + '</small>' +
                            '</div>' +
                            '</div>' +
                            unreadBadge +
                            '</a>';
                    });
                    html += '</div>';
                    widget.innerHTML = html;
                })
                .catch(function () {
                    widget.innerHTML = '<div class="text-center py-3 text-muted"><p class="small mb-0">Error loading messages.</p></div>';
                });
        }

        function setupSignalR() {
            try {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub')
                    .build();
                connection.on('ReceiveMessage', function () {
                    setTimeout(loadRecentMessages, 500);
                });
                connection.on('ReceiveNotification', function () {
                    setTimeout(loadRecentMessages, 500);
                });
                connection.start().catch(function () {});
            } catch (e) {}
        }

        function formatRelativeLocal(utcStr) {
            try {
                var d = new Date(utcStr);
                var now = new Date();
                var diffMs = now - d;
                var diffMin = Math.floor(diffMs / 60000);
                if (diffMin < 1) return 'Just now';
                if (diffMin < 60) return diffMin + 'm ago';
                var diffHr = Math.floor(diffMin / 60);
                if (diffHr < 24) return diffHr + 'h ago';
                var diffDay = Math.floor(diffHr / 24);
                if (diffDay < 7) return diffDay + 'd ago';
                return d.toLocaleDateString();
            } catch (e) { return ''; }
        }

        function escapeHtml(s) {
            if (s == null) return '';
            return String(s).replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>').replace(/"/g,'"').replace(/'/g,'&#039;');
        }
    </script>
}
