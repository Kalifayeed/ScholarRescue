@model ScholarRescue.ViewModels.Order.ClientDashboardViewModel

@{
    ViewData["Title"] = "Client Dashboard";
}

<style>
    .dashboard-header {
        background: linear-gradient(135deg, #0d47a1 0%, #1565c0 100%);
        color: white;
        padding: 2rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }

    .stat-card {
        border: none;
        border-radius: 8px;
        transition: transform 0.2s, box-shadow 0.2s;
        background: white;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
    }

    .stat-card.primary { border-left: 4px solid #0d47a1; }
    .stat-card.info { border-left: 4px solid #1976d2; }
    .stat-card.warning { border-left: 4px solid #f57c00; }
    .stat-card.success { border-left: 4px solid #388e3c; }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .stat-label {
        font-size: 0.95rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-header-custom {
        background: linear-gradient(135deg, #0d47a1 0%, #1565c0 100%);
        color: white;
        border: none;
    }

    .table-striped-custom tbody tr:nth-child(odd) {
        background-color: #f8f9fa;
    }

    .table-striped-custom tbody tr:hover {
        background-color: #e8f0fe;
    }

    .quick-action-btn {
        border-radius: 8px;
        padding: 1rem;
        text-align: center;
        transition: all 0.2s;
        background: white;
        border: 1px solid #e0e0e0;
    }

    .quick-action-btn:hover {
        border-color: #0d47a1;
        box-shadow: 0 4px 12px rgba(13, 71, 161, 0.15);
        transform: translateY(-2px);
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }

    .empty-state {
        padding: 3rem 1rem;
        text-align: center;
    }

    .empty-state-icon {
        font-size: 4rem;
        color: #ccc;
        margin-bottom: 1rem;
    }
</style>

<div class="container-fluid" style="max-width: 1400px;">
    <!-- Header -->
    <div class="dashboard-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="display-5 mb-1">
                <i class="bi bi-speedometer2"></i> My Dashboard
            </h1>
            <p class="mb-0 opacity-90">Welcome back! Here's your order overview.</p>
        </div>
        <a asp-action="Create" class="btn btn-light btn-lg">
            <i class="bi bi-plus-circle"></i> New Order
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Statistics Cards - Enhanced Grid -->
    <div class="row g-4 mb-5">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card stat-card primary shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <p class="stat-label text-muted mb-2">Total Orders</p>
                            <div class="stat-value text-primary">@Model.TotalOrders</div>
                        </div>
                        <i class="bi bi-file-text" style="font-size: 2rem; color: #0d47a1; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card stat-card info shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <p class="stat-label text-muted mb-2">Open</p>
                            <div class="stat-value text-info">@Model.OpenOrders</div>
                        </div>
                        <i class="bi bi-folder" style="font-size: 2rem; color: #1976d2; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card stat-card warning shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <p class="stat-label text-muted mb-2">In Progress</p>
                            <div class="stat-value text-warning">@Model.InProgressOrders</div>
                        </div>
                        <i class="bi bi-arrow-repeat" style="font-size: 2rem; color: #f57c00; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card stat-card success shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <p class="stat-label text-muted mb-2">Completed</p>
                            <div class="stat-value text-success">@Model.CompletedOrders</div>
                        </div>
                        <i class="bi bi-check-circle" style="font-size: 2rem; color: #388e3c; opacity: 0.3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="section-title">Quick Actions</h3>
            <div class="row g-3">
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-action="Create" class="quick-action-btn text-decoration-none text-dark">
                        <i class="bi bi-plus-circle-fill" style="font-size: 1.8rem; color: #0d47a1; display: block; margin-bottom: 0.5rem;"></i>
                        <strong class="d-block">New Order</strong>
                        <small class="text-muted">Create a new assignment</small>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="Messages" asp-action="Index" class="quick-action-btn text-decoration-none text-dark">
                        <i class="bi bi-chat-dots-fill" style="font-size: 1.8rem; color: #388e3c; display: block; margin-bottom: 0.5rem;"></i>
                        <strong class="d-block">Messages</strong>
                        <small class="text-muted">Chat with writers</small>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-action="Index" class="quick-action-btn text-decoration-none text-dark">
                        <i class="bi bi-file-earmark-text-fill" style="font-size: 1.8rem; color: #f57c00; display: block; margin-bottom: 0.5rem;"></i>
                        <strong class="d-block">My Orders</strong>
                        <small class="text-muted">View all orders</small>
                    </a>
                </div>
                <div class="col-12 col-sm-6 col-lg-3">
                    <a asp-controller="Notifications" asp-action="Index" class="quick-action-btn text-decoration-none text-dark">
                        <i class="bi bi-bell-fill" style="font-size: 1.8rem; color: #1976d2; display: block; margin-bottom: 0.5rem;"></i>
                        <strong class="d-block">Notifications</strong>
                        <small class="text-muted">Check updates</small>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content: Two-Column Layout -->
    <div class="row g-4 mb-5">
        <!-- Left Column: Recent Orders -->
        <div class="col-lg-8">
            <h3 class="section-title"><i class="bi bi-clock-history"></i> Recent Orders</h3>
            <div class="card shadow-sm">
                <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Latest Updates</h5>
                    <a asp-action="Index" class="btn btn-light btn-sm">
                        <i class="bi bi-arrow-right"></i> View All
                    </a>
                </div>
                <div class="card-body p-0">
            @if (!Model.RecentOrders.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h6 class="text-muted">No orders yet</h6>
                    <p class="text-muted small mb-3">Get started by creating your first order</p>
                    <a asp-action="Create" class="btn btn-primary">Create Your First Order</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped-custom align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 10%;">Order #</th>
                                <th style="width: 25%;">Title</th>
                                <th style="width: 18%;">Writer</th>
                                <th style="width: 12%;">Status</th>
                                <th style="width: 8%;">Pages</th>
                                <th style="width: 10%;">Budget</th>
                                <th style="width: 12%;">Deadline</th>
                                <th class="text-center" style="width: 5%;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td><strong>@order.OrderNumber</strong></td>
                                    <td>
                                        <span title="@order.Title">
                                            @(order.Title.Length > 35 ? order.Title[..35] + "..." : order.Title)
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(order.WriterName))
                                        {
                                            @order.WriterName
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic">Not assigned</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = order.Status switch
                                            {
                                                ScholarRescue.Models.Enums.OrderStatus.Draft => "bg-secondary",
                                                ScholarRescue.Models.Enums.OrderStatus.PendingReview => "bg-info text-dark",
                                                ScholarRescue.Models.Enums.OrderStatus.Open => "bg-primary",
                                                ScholarRescue.Models.Enums.OrderStatus.Assigned => "bg-primary",
                                                ScholarRescue.Models.Enums.OrderStatus.InProgress => "bg-warning text-dark",
                                        ScholarRescue.Models.Enums.OrderStatus.DraftSubmitted => "bg-info",
                                                ScholarRescue.Models.Enums.OrderStatus.RevisionRequested => "bg-warning text-dark",
                                                ScholarRescue.Models.Enums.OrderStatus.Completed => "bg-success",
                                                ScholarRescue.Models.Enums.OrderStatus.Cancelled => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@order.Status</span>
                                    </td>
                                    <td>@order.Pages</td>
                                    <td>@order.Budget.ToString("C")</td>
                                    <td>
                                        <span title="@order.Deadline.ToString("g")">
                                            @order.Deadline.ToString("MMM dd")
                                        </span>
                                    </td>
                                                    <td class="text-center">
                                                        <div class="btn-group btn-group-sm" role="group">
                                                            <a asp-action="Details" asp-route-id="@order.Id"
                                                               class="btn btn-outline-info" title="View Details">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                            @if (order.Status == OrderStatus.Assigned ||
                                                                 order.Status == OrderStatus.InProgress ||
                                                                 order.Status == OrderStatus.DraftSubmitted ||
                                                                 order.Status == OrderStatus.RevisionRequested)
                                                            {
                                                                <a asp-action="Workspace" asp-route-id="@order.Id"
                                                                   class="btn btn-outline-success" title="Open Workspace">
                                                                    <i class="bi bi-layout-sidebar"></i>
                                                                </a>
                                                            }
                                                            @if (order.Status != OrderStatus.Completed)
                                                            {
                                                                <a asp-action="Edit" asp-route-id="@order.Id"
                                                                   class="btn btn-outline-primary" title="Edit">
                                                                    <i class="bi bi-pencil"></i>
                                                                </a>
                                                            }
                                                        </div>
                                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
        </div>

        <!-- Right Column: Recent Messages -->
        <div class="col-lg-4">
            <h3 class="section-title"><i class="bi bi-chat-dots"></i> Recent Messages</h3>
            <div class="card shadow-sm">
                <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Conversations</h5>
                    <a asp-controller="Messages" asp-action="Index" class="btn btn-light btn-sm">
                        <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0" id="recentMessagesWidget">
                    <div class="text-center py-4">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted small mt-2 mb-0">Loading messages...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            loadRecentMessages();
            setupSignalR();
        });

        function loadRecentMessages() {
            var widget = document.getElementById('recentMessagesWidget');
            if (!widget) return;

            fetch('/Messages/Recent?take=5')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data || !data.success) {
                        widget.innerHTML = '<div class="empty-state"><div class="empty-state-icon"><i class="bi bi-exclamation-circle"></i></div><p class="text-muted small mb-0">Could not load messages.</p></div>';
                        return;
                    }
                    if (!data.conversations || data.conversations.length === 0) {
                        widget.innerHTML = '<div class="empty-state"><div class="empty-state-icon"><i class="bi bi-inbox"></i></div><p class="text-muted small mb-0">No recent messages</p><p class="text-muted" style="font-size:0.85rem;">Start a conversation with your assigned writer</p></div>';
                        return;
                    }
                    var html = '<div class="list-group list-group-flush">';
                    data.conversations.forEach(function (c) {
                        var time = formatRelativeLocal(c.lastMessageDate);
                        var unreadBadge = c.unreadCount > 0 ? '<span class="badge bg-danger rounded-pill ms-auto">' + c.unreadCount + '</span>' : '';
                        var online = c.isOtherPartyOnline
                            ? '<span class="text-success" title="Online"><i class="bi bi-circle-fill" style="font-size:0.6rem;"></i></span>'
                            : '<span class="text-muted" title="Offline"><i class="bi bi-circle" style="font-size:0.6rem;"></i></span>';
                        html += '<a href="/Messages/Conversation/' + c.conversationId + '" class="list-group-item list-group-item-action p-3 border-bottom">' +
                            '<div class="d-flex justify-content-between align-items-start gap-2">' +
                            '<div class="flex-grow-1 min-w-0">' +
                            '<div class="d-flex align-items-center gap-2 mb-1">' +
                            '<strong class="text-truncate" style="font-size:0.95rem;">' + escapeHtml(c.otherPartyName || 'Order ' + c.orderNumber) + '</strong>' +
                            online +
                            '</div>' +
                            '<small class="text-muted d-block mb-1">' + escapeHtml(c.orderNumber) + '</small>' +
                            '<div class="small text-muted text-truncate" style="font-size:0.85rem;">' +
                            escapeHtml(c.lastMessagePreview || 'No messages yet') +
                            '</div>' +
                            '</div>' +
                            '<div class="text-end flex-shrink-0">' +
                            '<small class="text-muted d-block mb-2">' + time + '</small>' +
                            unreadBadge +
                            '</div>' +
                            '</div>' +
                            '</a>';
                    });
                    html += '</div>';
                    widget.innerHTML = html;
                })
                .catch(function () {
                    widget.innerHTML = '<div class="empty-state"><div class="empty-state-icon"><i class="bi bi-exclamation-circle"></i></div><p class="text-muted small mb-0">Error loading messages.</p></div>';
                });
        }

        function setupSignalR() {
            try {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub')
                    .build();
                connection.on('ReceiveMessage', function () {
                    setTimeout(loadRecentMessages, 500);
                });
                connection.on('ReceiveNotification', function () {
                    setTimeout(loadRecentMessages, 500);
                });
                connection.start().catch(function () {});
            } catch (e) {}
        }

        function formatRelativeLocal(utcStr) {
            try {
                var d = new Date(utcStr);
                var now = new Date();
                var diffMs = now - d;
                var diffMin = Math.floor(diffMs / 60000);
                if (diffMin < 1) return 'Just now';
                if (diffMin < 60) return diffMin + 'm ago';
                var diffHr = Math.floor(diffMin / 60);
                if (diffHr < 24) return diffHr + 'h ago';
                var diffDay = Math.floor(diffHr / 24);
                if (diffDay < 7) return diffDay + 'd ago';
                return d.toLocaleDateString();
            } catch (e) { return ''; }
        }

        function escapeHtml(s) {
            if (s == null) return '';
            return String(s).replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>').replace(/"/g,'"').replace(/'/g,'&#039;');
        }
    </script>
}
