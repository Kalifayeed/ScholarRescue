@model ScholarRescue.ViewModels.Order.OrderDetailsViewModel

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete @Model.OrderNumber</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="card-title mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Confirm Deletion
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-info-circle"></i>
                        Are you sure you want to delete this order? This action cannot be undone.
                        Only orders in <strong>Draft</strong> or <strong>Open</strong> status can be deleted.
                    </div>

                    <dl class="row mb-4">
                        <dt class="col-sm-4 fw-bold">Order Number:</dt>
                        <dd class="col-sm-8">@Model.OrderNumber</dd>

                        <dt class="col-sm-4 fw-bold">Title:</dt>
                        <dd class="col-sm-8">@Model.Title</dd>

                        <dt class="col-sm-4 fw-bold">Subject:</dt>
                        <dd class="col-sm-8">@Model.Subject</dd>

                        <dt class="col-sm-4 fw-bold">Academic Level:</dt>
                        <dd class="col-sm-8">@Model.AcademicLevel</dd>

                        <dt class="col-sm-4 fw-bold">Pages:</dt>
                        <dd class="col-sm-8">@Model.Pages</dd>

                        <dt class="col-sm-4 fw-bold">Budget:</dt>
                        <dd class="col-sm-8 fw-bold text-success">@Model.Budget.ToString("C")</dd>

                        <dt class="col-sm-4 fw-bold">Status:</dt>
                        <dd class="col-sm-8">
                            @{
                            string statusBadgeClass = Model.Status switch
                            {
                                ScholarRescue.Models.Enums.OrderStatus.Draft => "bg-secondary",
                                ScholarRescue.Models.Enums.OrderStatus.PendingReview => "bg-info text-dark",
                                _ => "bg-secondary"
                            };
                            }
                            <span class="badge @statusBadgeClass">@Model.Status</span>
                        </dd>

                        <dt class="col-sm-4 fw-bold">Client:</dt>
                        <dd class="col-sm-8">@Model.ClientName</dd>

                        <dt class="col-sm-4 fw-bold">Created:</dt>
                        <dd class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy h:mm tt")</dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Delete Order
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}