@model ScholarRescue.ViewModels.Order.OrderBidsViewModel

@{
    ViewData["Title"] = $"Bids - {Model.OrderNumber}";
}

<div class="container-fluid px-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.OrderId">@Model.OrderNumber</a></li>
            <li class="breadcrumb-item active" aria-current="page">Bids</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="bi bi-hand-index-thumb"></i> Bids for @Model.OrderNumber</h1>
            <p class="text-muted mb-0">@Model.OrderTitle @(!string.IsNullOrEmpty(Model.OrderSubject) ? $"&mdash; {Model.OrderSubject}" : "")</p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Order
        </a>
    </div>

    @if (Model.IsAdmin)
    {
        <div class="alert alert-info">
            <i class="bi bi-shield-lock me-2"></i>
            Admin view — you see writer identities for order assignment.
        </div>
    }

    @if (!Model.Bids.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox display-3 text-muted"></i>
                <h5 class="mt-3 text-muted">No bids have been submitted for this order yet.</h5>
                <p class="text-muted">Check back later.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var bid in Model.Bids)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">
                                        @if (Model.IsAdmin)
                                        {
                                            <i class="bi bi-person-circle text-primary me-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-incognito text-secondary me-1"></i>
                                        }
                                        @bid.WriterDisplayName
                                    </h5>
                                    @if (!string.IsNullOrEmpty(bid.WriterEmail))
                                    {
                                        <small class="text-muted">@bid.WriterEmail</small>
                                    }
                                </div>
                                <div class="text-end">
                                    <h4 class="text-primary fw-bold mb-0">@bid.Amount.ToString("C")</h4>
                                    <span class="badge @(bid.Status == ScholarRescue.Models.Enums.OrderBidStatus.Pending ? "bg-warning text-dark" : bid.Status == ScholarRescue.Models.Enums.OrderBidStatus.Accepted ? "bg-success" : bid.Status == ScholarRescue.Models.Enums.OrderBidStatus.Rejected ? "bg-danger" : "bg-secondary")">
                                        @bid.Status
                                    </span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(bid.Message))
                            {
                                <div class="mb-3">
                                    <strong class="small text-muted">Proposal:</strong>
                                    <p class="mb-0">@bid.Message</p>
                                </div>
                            }

                            <div class="d-flex gap-3 small text-muted">
                                @if (bid.EstimatedDeliveryDate.HasValue)
                                {
                                    <span><i class="bi bi-calendar me-1"></i> Est. delivery: @bid.EstimatedDeliveryDate.Value.ToString("MMM dd, yyyy")</span>
                                }
                                <span><i class="bi bi-clock me-1"></i> Submitted: @bid.CreatedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (!Model.IsAdmin)
    {
        <div class="mt-4 p-3 bg-light rounded">
            <small class="text-muted">
                <i class="bi bi-shield-lock me-1"></i>
                Writer identities are hidden until the admin assigns a writer to this order.
            </small>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}