@model MessagingCenterViewModel
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid messaging-page">
    <div class="row g-0 messaging-shell">
        <!-- Left: Navigation Panel -->
        <div class="col-12 col-lg-4 col-xl-3 conversation-list-panel" id="conversationListPanel">
            <div class="card border-0 shadow-sm h-100 rounded-0">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-chat-dots"></i> Messages
                            @if (Model.TotalUnreadCount > 0)
                            {
                                <span class="badge bg-danger ms-1 unread-nav-badge">@Model.TotalUnreadCount</span>
                            }
                        </h5>
                        <div>
                            <a asp-action="NewMessage" class="btn btn-sm btn-light me-1" title="New Message">
                                <i class="bi bi-envelope-plus"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-light d-lg-none" id="closeListBtn" title="Close list">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Search + New Message Button -->
                <div class="p-3 border-bottom bg-light">
                    <form asp-action="Index" method="get" id="searchForm" class="messaging-search-form">
                        <div class="input-group input-group-sm mb-2">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" id="conversationSearch"
                                   class="form-control"
                                   placeholder="Search conversations & tickets..."
                                   value="@Model.SearchTerm" autocomplete="off" />
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <a asp-action="Index" class="btn btn-outline-secondary" title="Clear search">
                                    <i class="bi bi-x-circle"></i>
                                </a>
                            }
                        </div>
                    </form>
                    <a asp-action="NewMessage" class="btn btn-primary btn-sm w-100">
                        <i class="bi bi-envelope-plus"></i> New Message
                    </a>
                </div>

                <!-- Stats bar -->
                @if (Model.OpenTicketCount > 0)
                {
                    <div class="px-3 py-2 border-bottom bg-warning bg-opacity-10 small">
                        <i class="bi bi-ticket-perforated text-warning"></i>
                        <strong>@Model.OpenTicketCount</strong> open support ticket(s)
                    </div>
                }

                <!-- Tab: Conversations / Tickets -->
                <ul class="nav nav-tabs nav-fill small" id="messageTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="conv-tab" data-bs-toggle="tab" data-bs-target="#conv-panel" type="button" role="tab">
                            <i class="bi bi-chat"></i> Conversations
                            @if (Model.TotalUnreadCount > 0)
                            {
                                <span class="badge bg-danger ms-1">@Model.TotalUnreadCount</span>
                            }
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="ticket-tab" data-bs-toggle="tab" data-bs-target="#ticket-panel" type="button" role="tab">
                            <i class="bi bi-ticket"></i> Tickets
                            @if (Model.SupportTickets.Any(t => t.UnreadCount > 0))
                            {
                                <span class="badge bg-warning ms-1">@Model.SupportTickets.Count(t => t.UnreadCount > 0)</span>
                            }
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content card-body p-0 conversation-list-body" id="conversationListBody">
                    <!-- Conversations Tab -->
                    <div class="tab-pane fade show active" id="conv-panel" role="tabpanel">
                        @if (!Model.Conversations.Any())
                        {
                            <div class="text-center py-5 px-3 text-muted">
                                <i class="bi bi-inbox display-4 d-block mb-2"></i>
                                <h6>No conversations</h6>
                                <p class="small mb-0">
                                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                    {
                                        <text>No conversations match your search.</text>
                                    }
                                    else
                                    {
                                        <text>You have no active conversations yet. Open an order to start chatting with your writer.</text>
                                    }
                                </p>
                            </div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush conversation-list" id="conversationList">
                                @foreach (var conv in Model.Conversations)
                                {
                                    <li class="list-group-item list-group-item-action conversation-item @(conv.UnreadCount > 0 ? "unread" : "")"
                                        data-conversation-id="@conv.Id"
                                        data-href="@Url.Action("Conversation", new { id = conv.Id })">
                                        <div class="d-flex align-items-start">
                                            <div class="avatar-placeholder bg-primary text-white me-2 flex-shrink-0">
                                                @conv.OtherPartyName.Substring(0, 1)
                                            </div>
                                            <div class="flex-grow-1 min-w-0">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <strong class="text-truncate small">@conv.OtherPartyName</strong>
                                                    <small class="text-muted ms-2 conversation-time"
                                                           data-utc="@conv.LastMessageDate.ToString("o")">
                                                        @FormatRelative(conv.LastMessageDate)
                                                    </small>
                                                </div>
                                                <div class="text-truncate">
                                                    <small class="text-muted">
                                                        @if (!string.IsNullOrEmpty(conv.LastMessagePreview))
                                                        {
                                                            @conv.LastMessagePreview
                                                        }
                                                        else
                                                        {
                                                            <em>No messages yet</em>
                                                        }
                                                    </small>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                    <small class="text-primary">
                                                        <i class="bi bi-file-text"></i> @conv.OrderNumber
                                                    </small>
                                                    @if (conv.UnreadCount > 0)
                                                    {
                                                        <span class="badge bg-danger rounded-pill ms-2 unread-count">@conv.UnreadCount</span>
                                                    }
                                                    @if (conv.IsOtherPartyOnline)
                                                    {
                                                        <span class="text-success small"><i class="bi bi-circle-fill" style="font-size:0.5rem"></i> Online</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <!-- Tickets Tab -->
                    <div class="tab-pane fade" id="ticket-panel" role="tabpanel">
                        @if (!Model.SupportTickets.Any())
                        {
                            <div class="text-center py-5 px-3 text-muted">
                                <i class="bi bi-ticket-perforated display-4 d-block mb-2"></i>
                                <h6>No support tickets</h6>
                                <p class="small mb-0">
                                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                                    {
                                        <text>No tickets match your search.</text>
                                    }
                                    else
                                    {
                                        <text>You have no support tickets. Click "New Message" to contact a department.</text>
                                    }
                                </p>
                            </div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush ticket-list">
                                @foreach (var ticket in Model.SupportTickets)
                                {
                                    <li class="list-group-item list-group-item-action ticket-item @(ticket.UnreadCount > 0 ? "unread" : "")"
                                        data-href="@Url.Action("TicketDetail", new { id = ticket.Id })">
                                        <div class="d-flex align-items-start">
                                            <div class="me-2 flex-shrink-0">
                                                <span class="badge @GetStatusBadgeClass(ticket.Status)">@ticket.StatusDisplay</span>
                                            </div>
                                            <div class="flex-grow-1 min-w-0">
                                                <div class="d-flex justify-content-between">
                                                    <strong class="text-truncate small">[@ticket.TicketNumber] @ticket.Subject</strong>
                                                    <small class="text-muted ms-2"
                                                           data-utc="@ticket.CreatedAt.ToString("o")">
                                                        @FormatRelative(ticket.CreatedAt)
                                                    </small>
                                                </div>
                                                <div class="small text-muted">
                                                    <i class="bi bi-building"></i> @ticket.DepartmentDisplay
                                                    @if (!string.IsNullOrEmpty(ticket.QueueName))
                                                    {
                                                        <span class="ms-2"><i class="bi bi-arrow-right"></i> @ticket.QueueName</span>
                                                    }
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                    <small class="text-muted">
                                                        @if (ticket.LastReplyDate.HasValue)
                                                        {
                                                            <span>Last reply: @FormatRelative(ticket.LastReplyDate.Value)</span>
                                                        }
                                                    </small>
                                                    @if (ticket.UnreadCount > 0)
                                                    {
                                                        <span class="badge bg-warning rounded-pill ms-2">@ticket.UnreadCount new</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Empty state -->
        <div class="col-12 col-lg-8 col-xl-9 conversation-detail-panel" id="conversationDetailPanel">
            <div class="card border-0 shadow-sm h-100 rounded-0 empty-state-card">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center text-muted">
                    <i class="bi bi-chat-square-text display-1 mb-3"></i>
                    <h3>Welcome to Messages</h3>
                    <p class="mb-3">Select a conversation or ticket from the list to view details.</p>
                    <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center">
                        <a asp-action="NewMessage" class="btn btn-primary">
                            <i class="bi bi-envelope-plus"></i> New Message
                        </a>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-list-ul"></i> My Orders
                        </a>
                        <button type="button" class="btn btn-outline-secondary d-lg-none" id="openListBtn">
                            <i class="bi bi-list"></i> Browse
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .messaging-page, .messaging-shell { height: calc(100vh - 140px); min-height: 600px; }
    .conversation-list-panel, .conversation-detail-panel { height: 100%; }
    .conversation-list-body { overflow-y: auto; max-height: calc(100vh - 300px); }
    .conversation-item, .ticket-item { cursor: pointer; transition: background 0.15s ease; border-left: 3px solid transparent; }
    .conversation-item:hover, .ticket-item:hover { background: #f8f9fa; }
    .conversation-item.active, .ticket-item.active { background: #e7f1ff; border-left-color: #0d6efd; }
    .conversation-item.unread, .ticket-item.unread { background: #f0f7ff; }
    .avatar-placeholder { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 1rem; flex-shrink: 0; }
    .min-w-0 { min-width: 0; }
    .empty-state-card { background: #fafbfc; }
    .nav-tabs .nav-link { border-radius: 0; }
    @@media (max-width: 991.98px) {
        .conversation-list-panel { display: block; }
        .conversation-detail-panel { display: none; }
        .conversation-list-panel.hide-list { display: none; }
        .conversation-detail-panel.show-detail { display: block; }
    }
</style>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="~/lib/microsoft-signalr/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Make all list items clickable
            document.querySelectorAll('.conversation-item, .ticket-item').forEach(function (item) {
                item.addEventListener('click', function () {
                    var href = this.dataset.href;
                    if (href) window.location.href = href;
                });
            });

            // Mobile navigation
            var openBtn = document.getElementById('openListBtn');
            var closeBtn = document.getElementById('closeListBtn');
            if (openBtn) {
                openBtn.addEventListener('click', function () {
                    document.getElementById('conversationListPanel').classList.remove('hide-list');
                    document.getElementById('conversationDetailPanel').classList.remove('show-detail');
                });
            }
            if (closeBtn) {
                closeBtn.addEventListener('click', function () {
                    document.getElementById('conversationListPanel').classList.add('hide-list');
                    document.getElementById('conversationDetailPanel').classList.add('show-detail');
                });
            }

            // Live search
            var searchInput = document.getElementById('conversationSearch');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    var term = this.value.toLowerCase().trim();
                    document.querySelectorAll('.conversation-item, .ticket-item').forEach(function (item) {
                        var text = item.textContent.toLowerCase();
                        item.style.display = !term || text.indexOf(term) > -1 ? '' : 'none';
                    });
                });
            }

            // SignalR
            try {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/chatHub').build();

                connection.on('ReceiveMessage', function (msg) {
                    var items = document.querySelectorAll('.conversation-item');
                    items.forEach(function (item) {
                        if (item.dataset.conversationId == msg.conversationId) {
                            item.classList.add('unread');
                            item.style.transition = 'background 0.5s';
                            item.style.background = '#fff3cd';
                            setTimeout(function () { item.style.background = ''; }, 1200);
                        }
                    });
                    refreshUnreadCount();
                });

                connection.start().catch(function (err) { console.error('SignalR error:', err); });
            } catch (e) { console.warn('SignalR not initialized:', e); }

            function refreshUnreadCount() {
                fetch('/Messages/UnreadCount')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data && data.success) {
                            var badge = document.querySelector('.unread-nav-badge');
                            if (data.count > 0) {
                                if (badge) badge.textContent = data.count;
                            } else if (badge) { badge.remove(); }
                            var navBadge = document.getElementById('navbarUnreadCount');
                            if (navBadge) {
                                if (data.count > 0) { navBadge.textContent = data.count; navBadge.style.display = ''; }
                                else { navBadge.style.display = 'none'; }
                            }
                        }
                    }).catch(function (err) { console.error('Unread count error:', err); });
            }
        });

        function formatRelativeLocal(utcStr) {
            try {
                var d = new Date(utcStr);
                var now = new Date();
                var diffMs = now - d;
                var diffMin = Math.floor(diffMs / 60000);
                if (diffMin < 1) return 'Just now';
                if (diffMin < 60) return diffMin + 'm ago';
                var diffHr = Math.floor(diffMin / 60);
                if (diffHr < 24) return diffHr + 'h ago';
                var diffDay = Math.floor(diffHr / 24);
                if (diffDay < 7) return diffDay + 'd ago';
                return d.toLocaleDateString();
            } catch (e) { return ''; }
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('[data-utc]').forEach(function (el) {
                el.textContent = formatRelativeLocal(el.dataset.utc);
            });
        });
    </script>
}

@functions {
    private static string FormatRelative(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return local.ToString("MMM dd");
    }

    private static string GetStatusBadgeClass(TicketStatus status) => status switch
    {
        TicketStatus.Open => "bg-primary",
        TicketStatus.PendingResponse => "bg-warning text-dark",
        TicketStatus.InProgress => "bg-info text-dark",
        TicketStatus.WaitingForUser => "bg-secondary",
        TicketStatus.Resolved => "bg-success",
        TicketStatus.Closed => "bg-dark",
        _ => "bg-secondary"
    };
}