@model List<WriterEarningsReportRow>
@{
    ViewData["Title"] = "Writer Earnings Report";
    var fromDate = ViewBag.FromDate as DateTime?;
    var toDate = ViewBag.ToDate as DateTime?;
    var writerId = ViewBag.WriterId as string;
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Dashboard">Financial Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Writer Earnings Report</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-person-badge"></i> Writer Earnings Report</h1>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">From Date</label>
                    <input type="date" name="fromDate" class="form-control" value="@fromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">To Date</label>
                    <input type="date" name="toDate" class="form-control" value="@toDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Writer ID</label>
                    <input type="text" name="writerId" class="form-control" value="@writerId" placeholder="Filter by writer ID" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Filter</button>
                    <a asp-action="WriterEarningsReport" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i> Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Writer</th>
                            <th>Orders Completed</th>
                            <th>Total Earnings</th>
                            <th>Commission Paid</th>
                            <th>Pending Balance</th>
                            <th>Available Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No writer earnings data found.
                                </td>
                            </tr>
                        }
                        @foreach (var row in Model)
                        {
                            <tr>
                                <td><strong>@row.WriterName</strong><br /><small class="text-muted">@row.WriterId</small></td>
                                <td>@row.OrderCount</td>
                                <td>$@row.TotalEarnings.ToString("N2")</td>
                                <td>$@row.TotalCommissionPaid.ToString("N2")</td>
                                <td>$@row.PendingBalance.ToString("N2")</td>
                                <td>$@row.AvailableBalance.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td>TOTAL</td>
                            <td>@Model.Sum(r => r.OrderCount)</td>
                            <td>$@Model.Sum(r => r.TotalEarnings).ToString("N2")</td>
                            <td>$@Model.Sum(r => r.TotalCommissionPaid).ToString("N2")</td>
                            <td>$@Model.Sum(r => r.PendingBalance).ToString("N2")</td>
                            <td>$@Model.Sum(r => r.AvailableBalance).ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>