@model List<PayoutRequest>
@{
    ViewData["Title"] = "Payout Requests";
    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Dashboard">Financial Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Payout Requests</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-wallet2"></i> Payout Requests</h1>
        <div>
            <span class="badge @(ViewBag.PayoutWindowOpen ? "bg-success" : "bg-secondary") fs-6 me-2">
                <i class="bi bi-@(ViewBag.PayoutWindowOpen ? "check-circle" : "x-circle")"></i>
                @ViewBag.PayoutWindowMessage
            </span>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(currentFilter == "all" ? "active" : "")" asp-action="Payouts">All</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentFilter == "pending" ? "active" : "")" asp-action="Payouts" asp-route-status="pending">Pending</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentFilter == "approved" ? "active" : "")" asp-action="Payouts" asp-route-status="approved">Approved</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentFilter == "paid" ? "active" : "")" asp-action="Payouts" asp-route-status="paid">Paid</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentFilter == "rejected" ? "active" : "")" asp-action="Payouts" asp-route-status="rejected">Rejected</a>
        </li>
    </ul>

    <!-- Payouts Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Writer</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Requested</th>
                            <th>Approved/Paid</th>
                            <th>Transaction #</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No payout requests found.
                                </td>
                            </tr>
                        }
                        @foreach (var payout in Model)
                        {
                            <tr>
                                <td>@payout.Id</td>
                                <td>
                                    <strong>@payout.Writer?.FirstName @payout.Writer?.LastName</strong>
                                    <br /><small class="text-muted">@payout.Writer?.Email</small>
                                </td>
                                <td><strong>$@payout.Amount.ToString("N2")</strong></td>
                                <td>
                                    @switch (payout.Status)
                                    {
                                        case PayoutStatus.Pending:
                                            <span class="badge bg-warning text-dark">Pending</span>
                                            break;
                                        case PayoutStatus.Approved:
                                            <span class="badge bg-info text-dark">Approved</span>
                                            break;
                                        case PayoutStatus.Rejected:
                                            <span class="badge bg-danger">Rejected</span>
                                            break;
                                        case PayoutStatus.Paid:
                                            <span class="badge bg-success">Paid</span>
                                            break;
                                    }
                                </td>
                                <td>@payout.RequestedDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    @if (payout.ApprovedDate.HasValue)
                                    {
                                        @payout.ApprovedDate.Value.ToString("MMM dd, yyyy")
                                    }
                                    @if (payout.PayoutDate.HasValue)
                                    {
                                        <br /><small class="text-muted">Paid: @payout.PayoutDate.Value.ToString("MMM dd, yyyy")</small>
                                    }
                                </td>
                                <td><code>@payout.TransactionNumber</code></td>
                                <td>
                                    @if (payout.Status == PayoutStatus.Pending)
                                    {
                                        <div class="btn-group btn-group-sm">
                                            <form asp-action="ApprovePayout" method="post" style="display:inline;" onsubmit="return confirm('Approve this payout for $@payout.Amount.ToString("N2")?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@payout.Id" />
                                                <button type="submit" class="btn btn-success">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@payout.Id">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        </div>

                                        <!-- Reject Modal -->
                                        <div class="modal fade" id="rejectModal-@payout.Id" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <form asp-action="RejectPayout" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@payout.Id" />
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Reject Payout #@payout.Id</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p>Rejecting payout of <strong>$@payout.Amount.ToString("N2")</strong> for <strong>@payout.Writer?.FirstName @payout.Writer?.LastName</strong>.</p>
                                                            <p>Funds will be returned to the writer's available balance.</p>
                                                            <div class="mb-3">
                                                                <label class="form-label">Reason (optional)</label>
                                                                <textarea name="notes" class="form-control" rows="3" placeholder="Enter reason for rejection..."></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-danger">Reject Payout</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else if (payout.Status == PayoutStatus.Approved)
                                    {
                                        <form asp-action="MarkPayoutPaid" method="post" style="display:inline;" onsubmit="return confirm('Mark payout #@payout.Id as paid? This will deduct $@payout.Amount.ToString("N2") from platform balance.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@payout.Id" />
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <i class="bi bi-check-all"></i> Mark Paid
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            @if (!string.IsNullOrEmpty(payout.AdminNotes))
                            {
                                <tr class="table-light">
                                    <td colspan="8">
                                        <small class="text-muted">
                                            <strong>Admin Notes:</strong> @payout.AdminNotes
                                        </small>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>