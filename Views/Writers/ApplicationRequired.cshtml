@{
    ViewData["Title"] = "Application Required";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-5">
                    <i class="bi bi-clipboard-plus display-1 text-primary mb-3"></i>
                    <h2 class="h3 mb-3">Writer Application Required</h2>
                    <p class="text-muted">
                        You don't have a writer application on file. Please submit your application to begin
                        working as a tutor on ScholarRescue.
                    </p>
                    <a asp-controller="Account" asp-action="Register" asp-route-userType="Writer"
                       class="btn btn-primary mt-3">
                        <i class="bi bi-pencil-square"></i> Submit Writer Application
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
