@model WriterFinancialDashboardViewModel
@{
    ViewData["Title"] = "My Wallet";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Dashboard">Writer Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">My Wallet</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-wallet2"></i> My Wallet</h1>
        <div>
            <a asp-action="Transactions" class="btn btn-outline-primary">
                <i class="bi bi-journal-text"></i> Transactions
            </a>
            <a asp-action="Payouts" class="btn btn-outline-success">
                <i class="bi bi-cash-stack"></i> Payouts
            </a>
            <a asp-action="PaymentDetails" class="btn btn-outline-info">
                <i class="bi bi-credit-card"></i> Payment Details
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Balance Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-cash"></i> Available Balance</h5>
                    <h2 class="mb-0">$@Model.AvailableBalance.ToString("N2")</h2>
                    <small>Ready for payout</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-hourglass-split"></i> Pending Balance</h5>
                    <h2 class="mb-0">$@Model.PendingBalance.ToString("N2")</h2>
                    <small>Earnings awaiting release</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card border-info h-100">
                <div class="card-body">
                    <h5 class="card-title text-info"><i class="bi bi-graph-up"></i> Lifetime Earnings</h5>
                    <h3>$@Model.LifetimeEarnings.ToString("N2")</h3>
                    <small>Total earned since joining</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-secondary h-100">
                <div class="card-body">
                    <h5 class="card-title text-secondary"><i class="bi bi-wallet2"></i> Lifetime Payouts</h5>
                    <h3>$@Model.LifetimePayouts.ToString("N2")</h3>
                    <small>Total paid out to you</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Payout Window Status -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Payout Window Status</h5>
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center">
                <span class="badge @(Model.PayoutWindowOpen ? "bg-success" : "bg-secondary") fs-6 me-3">
                    <i class="bi bi-@(Model.PayoutWindowOpen ? "check-circle" : "x-circle")"></i>
                    @(Model.PayoutWindowOpen ? "OPEN" : "CLOSED")
                </span>
                <div>
                    <p class="mb-1">@Model.PayoutWindowMessage</p>
                    @if (!Model.PayoutWindowOpen)
                    {
                        <small class="text-muted">
                            Next window opens in: 
                            <strong>@Model.TimeUntilNextWindow.Days d @Model.TimeUntilNextWindow.Hours h @Model.TimeUntilNextWindow.Minutes m</strong>
                        </small>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Transactions</h5>
            <a asp-action="Transactions" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Debit</th>
                            <th>Credit</th>
                            <th>Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentTransactions.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No transactions yet.
                                </td>
                            </tr>
                        }
                        @foreach (var txn in Model.RecentTransactions)
                        {
                            <tr>
                                <td><small>@txn.CreatedDate.ToString("MMM dd, yyyy")</small></td>
                                <td>
                                    @switch (txn.TransactionType)
                                    {
                                        case TransactionType.WriterEarningAdded:
                                            <span class="badge bg-success">Earnings Added</span>
                                            break;
                                        case TransactionType.WriterEarningReleased:
                                            <span class="badge bg-info text-dark">Earnings Released</span>
                                            break;
                                        case TransactionType.PayoutRequested:
                                            <span class="badge bg-warning text-dark">Payout Requested</span>
                                            break;
                                        case TransactionType.PayoutApproved:
                                            <span class="badge bg-info text-dark">Payout Approved</span>
                                            break;
                                        case TransactionType.PayoutRejected:
                                            <span class="badge bg-danger">Payout Rejected</span>
                                            break;
                                        case TransactionType.PayoutPaid:
                                            <span class="badge bg-success">Payout Paid</span>
                                            break;
                                        case TransactionType.RefundIssued:
                                            <span class="badge bg-danger">Refund</span>
                                            break;
                                        case TransactionType.Adjustment:
                                            <span class="badge bg-secondary">Adjustment</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@txn.TransactionType</span>
                                            break;
                                    }
                                </td>
                                <td>@txn.Description</td>
                                <td class="text-danger">@(txn.DebitAmount > 0 ? $"${txn.DebitAmount:N2}" : "")</td>
                                <td class="text-success">@(txn.CreditAmount > 0 ? $"${txn.CreditAmount:N2}" : "")</td>
                                <td>$@txn.BalanceAfter.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>