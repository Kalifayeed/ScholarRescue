@model ScholarRescue.ViewModels.Writer.PlaceBidViewModel

@{
    ViewData["Title"] = "Place Bid";
}

<div class="container-fluid px-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="AvailableOrders">Available Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Place Bid</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-hand-index"></i> Place Your Bid</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-file-text fs-4 me-3"></i>
                            <div>
                                <strong>@Model.OrderNumber</strong> &mdash; @Model.OrderTitle
                                <br />
                                <small class="text-muted">Suggested budget: @Model.Amount.ToString("C")</small>
                            </div>
                        </div>
                    </div>

                    <form asp-action="PlaceBid" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="OrderTitle" />
                        <input type="hidden" asp-for="OrderNumber" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Message" class="form-label"></label>
                            <textarea asp-for="Message" class="form-control" rows="5"
                                      placeholder="Introduce yourself and explain why you are the best fit for this order. Include your relevant experience and approach."></textarea>
                            <small class="text-muted">Maximum 1000 characters.</small>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="EstimatedDeliveryDate" class="form-label"></label>
                            <input asp-for="EstimatedDeliveryDate" class="form-control" type="date" />
                            <small class="text-muted">When do you expect to complete this order?</small>
                            <span asp-validation-for="EstimatedDeliveryDate" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="AvailableOrders" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Submit Bid
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}