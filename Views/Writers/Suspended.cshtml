@model IEnumerable<ScholarRescue.ViewModels.Order.OrderIndexViewModel>
@{
    ViewData["Title"] = "Account Suspended";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-5">
                    <i class="bi bi-shield-exclamation display-1 text-danger mb-3"></i>
                    <h2 class="h3 mb-3">Account Suspended</h2>
                    <p class="text-muted">
                        Your writer account has been suspended. You currently cannot access orders,
                        messages, or earnings.
                    </p>
                    <p class="text-muted small">
                        If you believe this is a mistake, please contact our support team.
                    </p>
                    <div class="d-flex justify-content-center gap-2 mt-4">
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
