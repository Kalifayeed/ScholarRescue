@model List<FinancialTransaction>
@{
    ViewData["Title"] = "Transaction History";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Wallet">My Wallet</a></li>
            <li class="breadcrumb-item active" aria-current="page">Transaction History</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-journal-text"></i> Transaction History</h1>
        <a asp-action="Wallet" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back to Wallet
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead>
                        <tr>
                            <th>Transaction #</th>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Debit</th>
                            <th>Credit</th>
                            <th>Balance After</th>
                            <th>Date</th>
                            <th>Reference</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                    No transactions found.
                                </td>
                            </tr>
                        }
                        @foreach (var txn in Model)
                        {
                            <tr>
                                <td><code>@txn.TransactionNumber</code></td>
                                <td>
                                    @switch (txn.TransactionType)
                                    {
                                        case TransactionType.OrderCreated:
                                            <span class="badge bg-primary">Order Created</span>
                                            break;
                                        case TransactionType.OrderFunded:
                                            <span class="badge bg-success">Order Funded</span>
                                            break;
                                        case TransactionType.OrderCompleted:
                                            <span class="badge bg-info text-dark">Order Completed</span>
                                            break;
                                        case TransactionType.CommissionCharged:
                                            <span class="badge bg-warning text-dark">Commission</span>
                                            break;
                                        case TransactionType.WriterEarningAdded:
                                            <span class="badge bg-success">Earnings Added</span>
                                            break;
                                        case TransactionType.WriterEarningReleased:
                                            <span class="badge bg-info text-dark">Earnings Released</span>
                                            break;
                                        case TransactionType.PayoutRequested:
                                            <span class="badge bg-warning text-dark">Payout Requested</span>
                                            break;
                                        case TransactionType.PayoutApproved:
                                            <span class="badge bg-info text-dark">Payout Approved</span>
                                            break;
                                        case TransactionType.PayoutRejected:
                                            <span class="badge bg-danger">Payout Rejected</span>
                                            break;
                                        case TransactionType.PayoutPaid:
                                            <span class="badge bg-success">Payout Paid</span>
                                            break;
                                        case TransactionType.RefundIssued:
                                            <span class="badge bg-danger">Refund</span>
                                            break;
                                        case TransactionType.Adjustment:
                                            <span class="badge bg-secondary">Adjustment</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@txn.TransactionType</span>
                                            break;
                                    }
                                </td>
                                <td>@txn.Description</td>
                                <td class="text-danger">@(txn.DebitAmount > 0 ? $"${txn.DebitAmount:N2}" : "")</td>
                                <td class="text-success">@(txn.CreditAmount > 0 ? $"${txn.CreditAmount:N2}" : "")</td>
                                <td>$@txn.BalanceAfter.ToString("N2")</td>
                                <td><small>@txn.CreatedDate.ToString("MMM dd, yyyy HH:mm")</small></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(txn.ReferenceType) && txn.ReferenceId.HasValue)
                                    {
                                        <small>@txn.ReferenceType #@txn.ReferenceId</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <nav aria-label="Transaction history pagination" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Transactions" asp-route-page="@(currentPage - 1)">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            </li>
            <li class="page-item @(Model.Count < 20 ? "disabled" : "")">
                <a class="page-link" asp-action="Transactions" asp-route-page="@(currentPage + 1)">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
</div>